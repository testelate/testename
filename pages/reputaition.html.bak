<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>HUB.nexus — Reputaition</title>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="../css/global.css"/>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
  <style>
    body { display:flex; flex-direction:column; overflow:hidden; height:100vh; background:var(--bg); }
    .main { flex:1; display:flex; flex-direction:column; overflow:hidden; position:relative; }
    .bg-orbs { position:fixed; inset:0; pointer-events:none; z-index:0; overflow:hidden; }

    #navbar-container:not(:empty) ~ .main > .topbar .topbar-left { display:none !important; }
    #navbar-container:not(:empty) ~ .main > .topbar { justify-content:flex-end; padding-left:8px; height:46px; }

    .topbar { display:flex; align-items:center; justify-content:space-between; padding:0 20px; height:52px; flex-shrink:0; backdrop-filter:blur(30px); background:rgba(255,255,255,0.03); border-bottom:1px solid rgba(255,255,255,0.07); z-index:5; }
    .topbar-left { display:flex; align-items:center; gap:10px; }
    .topbar-badge { font-size:10px; padding:3px 9px; background:hsla(var(--theme-h),90%,50%,0.10); border:1px solid hsla(var(--theme-h),90%,50%,0.22); border-radius:var(--r-pill); color:var(--orange-2); display:flex; align-items:center; gap:5px; }
    .topbar-title { font-size:13px; font-weight:500; color:var(--text-primary); letter-spacing:-0.2px; }
    .topbar-right { display:flex; align-items:center; gap:8px; }

    .tbtn { display:inline-flex; align-items:center; gap:5px; padding:6px 12px; background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.09); border-radius:var(--r-sm); font-size:11px; color:var(--text-secondary); cursor:pointer; font-family:'Inter',sans-serif; transition:all var(--t-normal); }
    .tbtn:hover { background:rgba(255,255,255,0.09); }
    .tbtn svg { width:11px; height:11px; fill:none; stroke:currentColor; stroke-width:2; stroke-linecap:round; stroke-linejoin:round; }
    .tbtn-primary { background:hsla(var(--theme-h),90%,50%,0.12); border-color:hsla(var(--theme-h),90%,50%,0.28); color:var(--orange-2); }
    .tbtn-primary:hover { background:hsla(var(--theme-h),90%,50%,0.22); }
    .tbtn-danger { background:rgba(239,68,68,.10); border-color:rgba(239,68,68,.22); color:#f87171; }
    .tbtn-danger:hover { background:rgba(239,68,68,.20); }
    .tbtn:disabled { opacity:.45; cursor:not-allowed; }
    body.light .tbtn { background:rgba(255,255,255,0.70); border-color:rgba(180,100,40,0.18); color:#7a4a30; }

    .tabs-bar { display:flex; gap:2px; padding:0 20px; border-bottom:1px solid rgba(255,255,255,0.07); flex-shrink:0; background:rgba(255,255,255,0.02); overflow-x:auto; overflow-y:hidden; -webkit-overflow-scrolling:touch; }
    .main-tab { padding:10px 16px; font-size:12px; font-weight:400; color:var(--text-muted); cursor:pointer; border:none; background:transparent; font-family:'Inter',sans-serif; transition:all 0.18s; border-bottom:2px solid transparent; margin-bottom:-1px; display:flex; align-items:center; gap:6px; flex-shrink:0; white-space:nowrap; }
    .main-tab svg { width:12px; height:12px; fill:none; stroke:currentColor; stroke-width:1.8; stroke-linecap:round; stroke-linejoin:round; }
    .main-tab.active { color:var(--orange-2); border-bottom-color:var(--orange); }
    .main-tab:hover:not(.active) { color:var(--text-secondary); }

    .tab-body { flex:1; overflow-y:auto; overflow-x:hidden; padding:20px; position:relative; z-index:1; }

    .config-panel { padding:16px; background:hsla(var(--theme-h),90%,50%,0.04); border:1px solid hsla(var(--theme-h),90%,50%,0.14); border-radius:var(--r-lg); margin-bottom:16px; }
    .config-textarea { width:100%; height:80px; background:rgba(0,0,0,0.2); border:1px solid rgba(255,255,255,0.1); border-radius:var(--r-md); color:var(--text-secondary); padding:10px; font-family:'Inter', monospace; font-size:11px; margin-top:0; resize:vertical; box-sizing:border-box; outline:none; }
    .config-textarea:focus { border-color:hsla(var(--theme-h),90%,50%,0.40); }
    .macro-input { background:rgba(0,0,0,0.25); border:1px solid rgba(255,255,255,0.1); border-radius:var(--r-sm); padding:6px 10px; font-size:11px; color:var(--text-secondary); transition:border-color 0.2s; outline:none; box-sizing:border-box; font-family:'Inter',sans-serif; }
    .macro-input:focus { border-color:hsla(var(--theme-h),90%,50%,0.40); }
    body.light .macro-input, body.light .config-textarea { background:rgba(255,255,255,.8); border-color:rgba(180,100,40,.18); color:#3a1200; }
    body.light .config-panel { background:rgba(255,255,255,.6); border-color:rgba(180,100,40,.16); }

    .spinner { display:inline-block; width:12px; height:12px; border:2px solid rgba(255,128,64,0.3); border-top-color:#fff; border-radius:50%; animation:spin 0.7s linear infinite; vertical-align:middle; margin-right:5px; }
    @keyframes spin { to { transform:rotate(360deg); } }

    /* ── Enxoval cards ── */
    .enx-card { background:rgba(255,255,255,0.03); border:1px solid rgba(255,255,255,0.08); border-radius:var(--r-lg); padding:16px 18px; margin-bottom:12px; transition:border-color .18s; }
    .enx-card:hover { border-color:hsla(var(--theme-h),90%,50%,0.25); }
    .enx-tag { font-size:9px; font-weight:600; padding:2px 8px; border-radius:var(--r-pill); background:rgba(255,255,255,0.06); border:1px solid rgba(255,255,255,0.12); color:var(--text-muted); text-transform:uppercase; letter-spacing:.3px; }
    .enx-tag.cat { background:hsla(var(--theme-h),90%,50%,0.12); border-color:hsla(var(--theme-h),90%,50%,0.3); color:var(--orange-2); }
    body.light .enx-card { background:rgba(255,255,255,.6); border-color:rgba(180,100,40,.14); }

    /* ── Modal genérico ── */
    .ov-backdrop { position:fixed; inset:0; z-index:9998; background:rgba(0,0,0,.65); backdrop-filter:blur(4px); display:flex; align-items:center; justify-content:center; padding:20px; }
    .ov-box { background:hsl(var(--theme-h),22%,13%); border:1px solid rgba(255,255,255,.10); border-radius:16px; padding:26px; max-width:680px; width:100%; max-height:86vh; display:flex; flex-direction:column; box-shadow:0 24px 60px rgba(0,0,0,.55); }
    body.light .ov-box { background:#fff8f0; }
    .ov-head { display:flex; align-items:center; justify-content:space-between; margin-bottom:18px; }
    .ov-title { font-size:15px; font-weight:700; color:var(--text-primary); }
    .ov-close { background:none; border:none; color:var(--text-muted); font-size:20px; cursor:pointer; line-height:1; padding:4px; }
    .ov-body { overflow-y:auto; flex:1; }
    .ov-foot { display:flex; gap:10px; margin-top:18px; justify-content:flex-end; flex-wrap:wrap; }

    .field-label { font-size:12px; font-weight:600; color:var(--text-primary); display:block; margin-bottom:5px; }
    .field-hint { font-size:10px; color:var(--text-muted); line-height:1.5; margin-bottom:6px; }
  </style>
</head>
<body>
  <div class="bg-orbs">
    <div class="orb orb-1"></div><div class="orb orb-2"></div><div class="orb orb-3"></div>
  </div>
  <div id="navbar-container"></div>
  <div class="main">
    <div class="topbar">
      <div class="topbar-left">
        <img src="../assets/logo.png" alt="HUB.nexus" style="height:32px;width:auto;object-fit:contain;filter:drop-shadow(0 0 4px hsla(var(--theme-h),90%,50%,0.2));flex-shrink:0;"/>
        <span class="topbar-title">Reputaition</span>
        <div class="topbar-badge"><span class="pulse-dot"></span> Cadastro de cliente &amp; Enxoval de crise</div>
      </div>
      <div class="topbar-right">
        <a href="ekklesia.html" class="tbtn" title="Abrir Ekklesia for Social" style="text-decoration:none;">🏛️ Ekklesia Social</a>
        <a href="ekklesia-press.html" class="tbtn" title="Abrir Ekklesia for Press" style="text-decoration:none;">📰 Ekklesia Press</a>
        <button class="tbtn" onclick="toggleMode()">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/></svg>
        </button>
      </div>
    </div>
    <div class="tabs-bar">
      <button class="main-tab active" id="mtCadastro" onclick="setMainTab('cadastro',this)">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
        Cadastro de Cliente
      </button>
      <button class="main-tab" id="mtEnxoval" onclick="setMainTab('enxoval',this)">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
        Enxoval de Crise
      </button>
    </div>
    <div class="tab-body" id="tabBody"></div>
  </div>

  <!-- Modal genérico (texto completo / formulários) -->
  <div id="genModal" style="display:none;"></div>

  <!-- Modal do Ekklesia embutido -->
  <div id="ekklesiaModal" style="display:none;position:fixed;inset:0;z-index:9990;background:rgba(0,0,0,.72);backdrop-filter:blur(6px);display:none;flex-direction:column;">
    <div style="display:flex;align-items:center;justify-content:space-between;padding:10px 18px;background:hsl(var(--theme-h),22%,11%);border-bottom:1px solid rgba(255,255,255,.08);flex-shrink:0;">
      <div style="display:flex;align-items:center;gap:10px;">
        <span id="ekklesiaModalTitle" style="font-size:13px;font-weight:600;color:var(--text-primary);">🏛️ Ekklesia Social — Upload</span>
        <span style="font-size:10px;padding:2px 8px;border-radius:20px;background:hsla(var(--theme-h),90%,50%,0.12);border:1px solid hsla(var(--theme-h),90%,50%,0.28);color:var(--orange-2);">Ao unificar, a base volta automaticamente para cá</span>
      </div>
      <button onclick="fecharEkklesiaModal()" style="background:none;border:none;color:var(--text-muted);font-size:22px;cursor:pointer;line-height:1;padding:4px 8px;">✕</button>
    </div>
    <iframe id="ekklesiaIframe" src="" style="flex:1;border:none;width:100%;min-height:0;"></iframe>
    <div id="ekklesiaModalStatus" style="display:none;padding:12px 18px;background:rgba(102,221,136,0.09);border-top:1px solid rgba(102,221,136,0.22);font-size:12px;color:#66dd88;"></div>
  </div>

  <script src="../js/utils.js"></script>
  <script src="../js/theme.js"></script>
  <script src="../js/database.js"></script>
  <script src="../js/classificador-batch.js"></script>
  <script>
// ════════════════════════════════════════════════════════════
// HUB.nexus — Reputaition
// Cadastro de cliente (wizard de premissas) + Enxoval de Crise
// Extraído do módulo Ekklesia for Social (aba "Reputaition") para
// ser um fluxo independente, com capacidade de importar bases do
// Ekklesia Social (IndexedDB) e do Ekklesia Press (XLSX exportado).
// ════════════════════════════════════════════════════════════

checkAuth(); initMode();
if (typeof initTheme === 'function') initTheme();

// ── Modal Ekklesia embutido (iframe same-origin) ───────────────────────────
function abrirEkklesiaModal(tipo) {
  const modal = document.getElementById('ekklesiaModal');
  const iframe = document.getElementById('ekklesiaIframe');
  const title  = document.getElementById('ekklesiaModalTitle');
  const status = document.getElementById('ekklesiaModalStatus');
  if (!modal || !iframe) return;
  const src = tipo === 'press'
    ? '../pages/ekklesia-press.html?mode=iframe'
    : '../pages/ekklesia.html?mode=iframe';
  title.textContent = tipo === 'press'
    ? '📰 Ekklesia Press — Upload'
    : '🏛️ Ekklesia Social — Upload';
  iframe.src = src;
  status.style.display = 'none';
  modal.style.display = 'flex';
  document.body.style.overflow = 'hidden';
}
function fecharEkklesiaModal() {
  const modal = document.getElementById('ekklesiaModal');
  const iframe = document.getElementById('ekklesiaIframe');
  if (modal) modal.style.display = 'none';
  if (iframe) iframe.src = ''; // descarrega o iframe
  document.body.style.overflow = '';
}

// Ouve postMessage do Ekklesia dentro do iframe
window.addEventListener('message', e => {
  if (!e.data || e.data.type !== 'ekklesia-unificado') return;
  const rows = e.data.rows || [];
  if (!rows.length) return;
  const antes = repDB.length;
  repDB = mesclarNaRepDB(rows);
  repSalvarDBSessao();
  const novos = repDB.length - antes;
  // Mostra status na barra do modal por 2s, depois fecha
  const status = document.getElementById('ekklesiaModalStatus');
  if (status) {
    status.style.display = 'block';
    status.textContent = `✅ ${novos.toLocaleString('pt-BR')} publicações incorporadas! Fechando…`;
  }
  showToastSafe(`✅ ${novos.toLocaleString('pt-BR')} publicações do Ekklesia prontas no Reputaition!`);
  setTimeout(() => {
    fecharEkklesiaModal();
    renderReputaition();
  }, 1800);
});

let mainTab = 'cadastro'; // 'cadastro' | 'enxoval'
function setMainTab(tab, el) {
  mainTab = tab;
  document.querySelectorAll('.main-tab').forEach(b => b.classList.remove('active'));
  if (el) el.classList.add('active');
  if (tab === 'cadastro') renderReputaition();
  else renderEnxoval();
}

const REP_BASE_URL = 'https://app.reputaition.nexus.fsb.com.br';

// ── Base de trabalho local (independente do Ekklesia) ──────────
// Cada linha segue, na medida do possível, o mesmo formato interno
// usado pelo Ekklesia for Social, para reaproveitar os conversores.
let repDB = JSON.parse(sessionStorage.getItem('rep_db_sessao') || '[]');

function repSalvarDBSessao() {
  try { sessionStorage.setItem('rep_db_sessao', JSON.stringify(repDB)); } catch(e) {}
}

function showToastSafe(msg) { if (typeof showToast === 'function') showToast(msg); else alert(msg); }

// ── Helpers de data/canal/sentimento (portados do Ekklesia) ──────
function parseDateCustom(dStr) {
  if (!dStr && dStr !== 0) return null;
  const raw = typeof dStr === 'number' ? dStr : null;
  const asNum = raw ?? (typeof dStr === 'string' && /^\d+([.,]\d+)?$/.test(String(dStr).trim())
    ? Number(String(dStr).trim().replace(',', '.')) : NaN);
  if (!isNaN(asNum)) {
    if (asNum > 25569 && asNum < 73050) {
      const d = new Date(Math.round((asNum - 25569) * 86400 * 1000));
      return isNaN(d) ? null : d.toISOString().substring(0, 19).replace('T', ' ');
    }
    if (asNum > 1e9 && asNum < 2e10) { const d = new Date(asNum * 1000); return isNaN(d) ? null : d.toISOString().substring(0,19).replace('T',' '); }
    if (asNum > 1e12) { const d = new Date(asNum); return isNaN(d) ? null : d.toISOString().substring(0,19).replace('T',' '); }
    return null;
  }
  const s = String(dStr).trim();
  if (!s) return null;
  const mBR = s.match(/^(\d{2})\/(\d{2})\/(\d{2,4})([\s,T](.*))?$/);
  if (mBR) { const yr = mBR[3].length === 2 ? '20'+mBR[3] : mBR[3]; return `${yr}-${mBR[2]}-${mBR[1]}` + (mBR[5] ? ' '+mBR[5].trim() : ''); }
  const mISO = s.match(/^(\d{4})[-\/](\d{2})[-\/](\d{2})/);
  if (mISO) return s.replace(/\//g,'-').substring(0,19);
  const d = new Date(s);
  if (!isNaN(d)) return d.toISOString().substring(0,19).replace('T',' ');
  return null;
}
function canonSent(v){
  if(!v) return '';
  const raw = String(v).toLowerCase().trim();
  const m={ 'positive':'Positivo','very positive':'Positivo','negative':'Negativo','very negative':'Negativo','neutral':'Neutro',
    'positivo':'Positivo','negativo':'Negativo','neutro':'Neutro','favoravel':'Favorável','favorável':'Favorável',
    'desfavoravel':'Desfavorável','desfavorável':'Desfavorável','muito positivo':'Positivo','muito negativo':'Negativo' };
  return m[raw] || (raw.charAt(0).toUpperCase() + raw.slice(1));
}
function _csvCell(v) { const s = (v == null ? '' : String(v)).replace(/\r?\n/g,' ').trim(); return /[",;]/.test(s) ? `"${s.replace(/"/g,'""')}"` : s; }
function _contaPalavras(s) { const t = String(s ?? '').trim(); return t ? t.split(/\s+/).length : 0; }

// ── IMPORTAR BASE — Ekklesia Social (lê direto do IndexedDB compartilhado) ──
async function repPuxarEkklesiaSocial() {
  const btn = document.getElementById('repImportSocialBtn');
  if (btn) { btn.disabled = true; btn.innerHTML = '<span class="spinner"></span> Lendo base do Ekklesia…'; }
  try {
    await dbProvider.init();
    const rows = await new Promise((resolve, reject) => {
      const out = [];
      const tx = dbProvider.db.transaction(['publicacoes'], 'readonly');
      const store = tx.objectStore('publicacoes');
      const cursorReq = store.openCursor();
      cursorReq.onsuccess = e => {
        const cursor = e.target.result;
        if (cursor) { out.push(cursor.value); cursor.continue(); }
        else resolve(out);
      };
      cursorReq.onerror = reject;
    });
    if (!rows.length) {
      showToastSafe('⚠️ Não há nenhuma base processada no Ekklesia Social ainda. Abra o Ekklesia, processe os arquivos na aba Upload e volte aqui.');
      return;
    }
    repDB = mesclarNaRepDB(rows.map(r => ({ ...r, _origem: r._origem || 'social' })));
    repSalvarDBSessao();
    showToastSafe(`✅ ${rows.length.toLocaleString('pt-BR')} publicações puxadas do Ekklesia Social.`);
    renderReputaition();
  } catch(e) {
    console.error(e);
    showToastSafe('❌ Não consegui ler a base do Ekklesia Social: ' + e.message);
  } finally {
    if (btn) { btn.disabled = false; btn.innerHTML = '📊 Puxar base do Ekklesia Social'; }
  }
}

// ── IMPORTAR BASE — Ekklesia Press (XLSX exportado pela aba "Export Geral") ──
function repAbrirImportacaoPress() {
  const inp = document.createElement('input');
  inp.type = 'file'; inp.accept = '.csv,.xlsx,.xls';
  inp.onchange = e => { if (e.target.files[0]) repImportarPressXLSX(e.target.files[0]); };
  inp.click();
}
async function repImportarPressXLSX(file) {
  const btn = document.getElementById('repImportPressBtn');
  if (btn) { btn.disabled = true; btn.innerHTML = '<span class="spinner"></span> Lendo arquivo…'; }
  try {
    const rows = await new Promise((resolve, reject) => {
      const reader = new FileReader();
      reader.onload = ev => {
        try {
          const wb = XLSX.read(new Uint8Array(ev.target.result), { type:'array' });
          resolve(XLSX.utils.sheet_to_json(wb.Sheets[wb.SheetNames[0]], { defval:'' }));
        } catch(err) { reject(err); }
      };
      reader.onerror = reject;
      reader.readAsArrayBuffer(file);
    });
    if (!rows.length) throw new Error('Arquivo vazio ou formato não reconhecido.');
    const norm = s => String(s||'').toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g,'').trim();
    const hdr = Object.keys(rows[0]);
    const idx = {}; hdr.forEach(h => idx[norm(h)] = h);
    const resolve_ = (...aliases) => { for (const a of aliases) { const k = idx[norm(a)]; if (k !== undefined) return k; } return null; };
    const K = {
      data: resolve_('Data'), veiculo: resolve_('Veículo','Veiculo'), titulo: resolve_('Título','Titulo'),
      link: resolve_('Link'), tipo_midia: resolve_('Tipo de Mídia','Tipo de Midia'),
      valorizacao: resolve_('Valoração','Valoracao'), sentimento: resolve_('Sentimento'),
      porta_voz: resolve_('Porta-voz','Porta voz'), assunto: resolve_('Assunto Principal'),
      empresa: resolve_('Empresa'), fonte_clip: resolve_('Fonte Clipadora'), conteudo: resolve_('Conteúdo','Conteudo','Texto'),
    };
    const mapeado = rows.map(r => ({
      fonte: 'press', canal: K.veiculo ? (r[K.veiculo]||'') : '',
      data: K.data ? parseDateCustom(r[K.data]) : null,
      titulo: K.titulo ? (r[K.titulo]||'') : '',
      conteudo: K.conteudo ? (r[K.conteudo]||'') : '',
      link_publicacao: K.link ? (r[K.link]||'') : '',
      tipo_midia: K.tipo_midia ? (r[K.tipo_midia]||'') : '',
      valorizacao: K.valorizacao ? (r[K.valorizacao]||'') : '',
      sentimento: K.sentimento ? canonSent(r[K.sentimento]) : '',
      porta_voz_origem: K.porta_voz ? (r[K.porta_voz]||'') : '',
      assunto_principal: K.assunto ? (r[K.assunto]||'') : '',
      empresa: K.empresa ? (r[K.empresa]||'') : '',
      fonte_clipadora: K.fonte_clip ? (r[K.fonte_clip]||'') : '',
      _origem: 'press',
    })).filter(r => r.canal || r.titulo || r.conteudo);
    if (!mapeado.length) throw new Error('Nenhuma linha reconhecida — confirme que é a planilha "Exportar Base" do Ekklesia Press.');
    repDB = mesclarNaRepDB(mapeado);
    repSalvarDBSessao();
    showToastSafe(`✅ ${mapeado.length.toLocaleString('pt-BR')} matérias importadas do Ekklesia Press.`);
    renderReputaition();
  } catch(e) {
    console.error(e);
    showToastSafe('❌ Erro ao importar: ' + e.message);
  } finally {
    if (btn) { btn.disabled = false; btn.innerHTML = '📰 Importar Excel do Ekklesia Press'; }
  }
}

// Mescla novas linhas na repDB evitando duplicatas grosseiras
function mesclarNaRepDB(novas) {
  const base = novas.concat(repDB);
  const seen = new Set();
  return base.filter(r => {
    const key = (r.link_publicacao||'') + '|' + (r.titulo||'').substring(0,60) + '|' + (r.conteudo||'').substring(0,60) + '|' + (r.data||'');
    if (seen.has(key)) return false;
    seen.add(key); return true;
  });
}

function repLimparBase() {
  if (!confirm('Limpar a base importada nesta sessão? Isso não afeta o Ekklesia, só a amostra local usada aqui.')) return;
  repDB = []; repSalvarDBSessao(); renderReputaition();
}

// ── IMPORTAR BASE AVULSA — qualquer planilha (Stilingue, Brandwatch, etc.) ──
function repImportarAvulso() {
  const inp = document.createElement('input');
  inp.type = 'file'; inp.accept = '.csv,.xlsx,.xls';
  inp.onchange = async e => {
    const file = e.target.files[0]; if (!file) return;
    const status = document.getElementById('repAvulsoStatus');
    if (status) status.innerHTML = '<span class="spinner"></span> Lendo arquivo…';
    try {
      const rawRows = await new Promise((res, rej) => {
        const reader = new FileReader();
        reader.onload = ev => {
          try {
            const wb = XLSX.read(new Uint8Array(ev.target.result), { type:'array' });
            res(XLSX.utils.sheet_to_json(wb.Sheets[wb.SheetNames[0]], { defval:'' }));
          } catch(err) { rej(err); }
        };
        reader.onerror = rej;
        reader.readAsArrayBuffer(file);
      });
      if (!rawRows.length) throw new Error('Arquivo vazio ou formato não reconhecido.');
      // Tenta primeiro o parser do Ekklesia Press (detecta vetores como Stilingue, Info4, etc.)
      const norm = s => String(s||'').toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g,'').trim();
      const hdr = Object.keys(rawRows[0]);
      const idx = {}; hdr.forEach(h => idx[norm(h)] = h);
      const resolve_ = (...aliases) => { for (const a of aliases) { const k = idx[norm(a)]; if (k !== undefined) return k; } return null; };
      const hasPress = !!(resolve_('Veículo','Veiculo') || resolve_('Tipo de Mídia','Tipo de Midia') || resolve_('Valoração','Valoracao'));
      let mapeado;
      if (hasPress) {
        // Reusar o parser de press já existente
        const K = {
          data: resolve_('Data'), veiculo: resolve_('Veículo','Veiculo'), titulo: resolve_('Título','Titulo'),
          link: resolve_('Link'), tipo_midia: resolve_('Tipo de Mídia','Tipo de Midia'),
          valorizacao: resolve_('Valoração','Valoracao'), sentimento: resolve_('Sentimento'),
          porta_voz: resolve_('Porta-voz','Porta voz'), assunto: resolve_('Assunto Principal'),
          empresa: resolve_('Empresa'), fonte_clip: resolve_('Fonte Clipadora'), conteudo: resolve_('Conteúdo','Conteudo','Texto'),
        };
        mapeado = rawRows.map(r => ({
          fonte: 'press', canal: K.veiculo ? (r[K.veiculo]||'') : '',
          data: K.data ? parseDateCustom(r[K.data]) : null,
          titulo: K.titulo ? (r[K.titulo]||'') : '',
          conteudo: K.conteudo ? (r[K.conteudo]||'') : '',
          link_publicacao: K.link ? (r[K.link]||'') : '',
          tipo_midia: K.tipo_midia ? (r[K.tipo_midia]||'') : '',
          sentimento: K.sentimento ? canonSent(r[K.sentimento]) : '',
          _origem: 'press_avulso',
        })).filter(r => r.canal || r.titulo || r.conteudo);
      } else {
        // Parser genérico (Stilingue, Brandwatch, Sprinklr, etc.)
        mapeado = parseRowsReputation(rawRows).map(r => ({ ...r, _origem: 'avulso' }));
      }
      if (!mapeado.length) throw new Error('Nenhuma linha reconhecida. Verifique se o arquivo tem colunas de conteúdo, data ou canal.');
      const antes = repDB.length;
      repDB = mesclarNaRepDB(mapeado);
      repSalvarDBSessao();
      const novos = repDB.length - antes;
      if (status) status.innerHTML = `<span style="color:#66dd88;">✅ ${novos.toLocaleString('pt-BR')} registros adicionados (${hasPress?'formato press':'formato social/genérico'}). Total: ${repDB.length.toLocaleString('pt-BR')}.</span>`;
      showToastSafe(`✅ ${novos.toLocaleString('pt-BR')} registros importados!`);
      renderReputaition();
    } catch(e) {
      const status = document.getElementById('repAvulsoStatus');
      if (status) status.innerHTML = `<span style="color:var(--red);">❌ ${e.message}</span>`;
      showToastSafe('❌ ' + e.message);
    }
  };
  inp.click();
}

// ════════════════════════════════════════════════════════════
// CADASTRO DE CLIENTE — wizard de premissas (13 passos)
// ════════════════════════════════════════════════════════════
let repAnchors = Object.assign({
  nome: '', empresa_id: '', gov: false, cadastrar_concorrentes: false,
  nome_marca: '',
  termos: '', termos_tags: '',
  programas: '', campanhas: '', slogans: '', apelidos: '', produtos: '',
  regras_globais: '', logica_etapa1: '', logica_etapa2: '',
  foco_cliente: '', foco_concorrente: '',
  foco_cliente_rs: '', foco_cliente_imp: '', foco_concorrente_rs: '', foco_concorrente_imp: '',
  pub_positivo: '', termos_positivo: '', prem_positivo: '',
  pub_negativo: '', termos_negativo: '', prem_negativo: '',
  pub_favoravel: '', termos_favoravel: '', prem_favoravel: '',
  pub_desfavoravel: '', termos_desfavoravel: '', prem_desfavoravel: '',
  prem_neutro: '',
  pub_pos_fav: '', termos_pos_fav: '', pub_neg_des: '', termos_neg_des: '',
  mensagens_chave: [], grupos_temas: [], temas: [], porta_vozes: [], tipos_pub: [], canais: [],
}, JSON.parse(localStorage.getItem('rep_anchors') || 'null') || {});

const REP_CAMPOS = [
  { key:'programas', label:'Programas e Iniciativas', hint:'Programas e iniciativas separados por ponto e vírgula (;)' },
  { key:'campanhas', label:'Campanhas Publicitárias', hint:'Campanhas publicitárias separadas por ponto e vírgula (;)' },
  { key:'slogans',   label:'Slogans',                 hint:'Slogans separados por ponto e vírgula (;)' },
  { key:'apelidos',  label:'Apelidos e Nomes Comuns',  hint:'Apelidos e nomes comuns separados por ponto e vírgula (;)' },
  { key:'produtos',  label:'Produtos',                hint:'Produtos separados por ponto e vírgula (;)' },
];

const REP_PASSOS = [
  { id:'dados',       titulo:'Empresa — Dados e Concorrentes', tipo:'hub',     repSec:null },
  { id:'marcas',      titulo:'Empresa — Detecção de Citação',  tipo:'hub',     repSec:'Detecção de Citação no Título' },
  { id:'msg',         titulo:'Mensagem-Chave',                 tipo:'hub',     repSec:'Mensagem-Chave' },
  { id:'grupos',      titulo:'Grupos de Temas Monitorados',    tipo:'hub',     repSec:'Grupos de Temas Monitorados' },
  { id:'temas',       titulo:'Temas Monitorados',              tipo:'hub',     repSec:'Temas Monitorados' },
  { id:'testar_temas',titulo:'Testar Temas',                   tipo:'hub',     repSec:null },
  { id:'prompt',      titulo:'Configuração de Prompt',         tipo:'hub',     repSec:'Configuração de Prompt' },
  { id:'canais',      titulo:'Canais Monitorados',             tipo:'parcial', repSec:'Canais Monitorados' },
  { id:'porta',       titulo:'Porta-vozes',                    tipo:'hub',     repSec:'Porta-vozes' },
  { id:'pubs',        titulo:'Tipos de Publicadores',          tipo:'hub',     repSec:'Tipos de Publicadores' },
  { id:'clip',        titulo:'Clipadoras da Empresa',          tipo:'parcial', repSec:'Clipadoras da Empresa' },
  { id:'vincular',    titulo:'Vincular empresa ao HUB',        tipo:'hub',     repSec:null },
  { id:'classificar', titulo:'Classificar e Refinar',          tipo:'hub',     repSec:null },
];

function repTipoBadge(tipo) {
  if (tipo==='hub')     return '<span style="font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:.4px;color:#66dd88;background:rgba(102,221,136,0.12);border:1px solid rgba(102,221,136,0.3);border-radius:6px;padding:2px 7px;">HUB ajuda</span>';
  if (tipo==='parcial') return '<span style="font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:.4px;color:#88aaff;background:rgba(136,170,255,0.12);border:1px solid rgba(136,170,255,0.3);border-radius:6px;padding:2px 7px;">HUB esboça</span>';
  return '<span style="font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:.4px;color:var(--text-muted);background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.12);border-radius:6px;padding:2px 7px;">Manual no Reputaition</span>';
}

let repPasso = parseInt(sessionStorage.getItem('rep_passo_sessao') || '0') || 0;
function repIrPasso(n) {
  const total = REP_PASSOS.length;
  repPasso = Math.max(0, Math.min(total - 1, n));
  sessionStorage.setItem('rep_passo_sessao', String(repPasso));
  renderReputaition();
  document.getElementById('tabBody')?.scrollIntoView({ behavior:'smooth', block:'start' });
}

let repFonte = null; // null | 'base' | 'briefing'
function repEscolherFonte(f) {
  repFonte = f;
  renderReputaition();
  setTimeout(() => document.getElementById('rep_nome')?.focus(), 120);
}

function repToggleGate() {
  const box = document.getElementById('repEntryBox');
  if (!box) return;
  const ok = !!(document.getElementById('rep_nome')?.value || '').trim();
  box.style.opacity = ok ? '1' : '0.5';
  box.style.pointerEvents = ok ? 'auto' : 'none';
}

function repExtrairId(input) {
  if (!input) return '';
  const txt = input.trim();
  const m = txt.match(/empresas\/([0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12})/i);
  if (m) return m[1];
  const u = txt.match(/^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i);
  if (u) return txt;
  return '';
}

function repSync() {
  ['termos','termos_tags','programas','campanhas','slogans','apelidos','produtos',
   'regras_globais','logica_etapa1','logica_etapa2','foco_cliente','foco_concorrente',
   'foco_cliente_rs','foco_cliente_imp','foco_concorrente_rs','foco_concorrente_imp',
   'pub_positivo','termos_positivo','prem_positivo',
   'pub_negativo','termos_negativo','prem_negativo',
   'pub_favoravel','termos_favoravel','prem_favoravel',
   'pub_desfavoravel','termos_desfavoravel','prem_desfavoravel',
   'prem_neutro','pub_pos_fav','termos_pos_fav','pub_neg_des','termos_neg_des'].forEach(k => {
    const el = document.getElementById('rep_' + k);
    if (el) repAnchors[k] = el.value;
  });
  const nomeEl = document.getElementById('rep_nome'); if (nomeEl) repAnchors.nome = nomeEl.value;
  const nomeMarcaEl = document.getElementById('rep_nome_marca'); if (nomeMarcaEl) repAnchors.nome_marca = nomeMarcaEl.value;
  const govEl = document.getElementById('rep_gov'); if (govEl) repAnchors.gov = govEl.checked;
  const concEl = document.getElementById('rep_cadastrar_concorrentes'); if (concEl) repAnchors.cadastrar_concorrentes = concEl.checked;
  localStorage.setItem('rep_anchors', JSON.stringify(repAnchors));
}

function repQuoteTermo(t) {
  const s = String(t || '').trim();
  if (!s) return '';
  if (/^".*"$/.test(s)) return s;                        // já tem aspas
  if (/^@/.test(s)) return s;                             // handle @
  if (/\b(OR|AND|NOT)\b/.test(s)) return s;              // booleano
  if (/\s/.test(s)) return `"${s.replace(/"/g,'')}"`;    // multi-palavra
  return s;
}

// Classifica um termo para o preview de chips (igual ao Reputaition)
function repClassTermo(t) {
  const s = String(t || '').trim();
  if (!s) return null;
  if (/^@/.test(s))                   return { tipo: 'handle',   cor: '#88aaff', bg: 'rgba(136,170,255,0.10)', brd: 'rgba(136,170,255,0.30)' };
  if (/\b(OR|AND|NOT)\b/.test(s))     return { tipo: 'booleano', cor: '#d88aff', bg: 'rgba(216,138,255,0.10)', brd: 'rgba(216,138,255,0.28)' };
  if (/^".*"$/.test(s) || /\s/.test(s)) return { tipo: 'multi',  cor: 'var(--orange-2)', bg: 'rgba(255,170,40,0.10)', brd: 'rgba(255,170,40,0.30)' };
  return { tipo: 'simples', cor: 'var(--text-secondary)', bg: 'rgba(255,255,255,0.06)', brd: 'rgba(255,255,255,0.14)' };
}

// Gera chips estilo Reputaition a partir de um campo de termos
function repChipsPreview(val) {
  const termos = String(val || '').split(/;|\n/).map(s => s.trim()).filter(Boolean);
  if (!termos.length) return '';
  return termos.map(t => {
    const quoted = repQuoteTermo(t);
    const cl = repClassTermo(quoted);
    if (!cl) return '';
    return `<span style="display:inline-flex;align-items:center;gap:4px;margin:2px 4px 2px 0;padding:2px 9px;border-radius:20px;font-size:10px;background:${cl.bg};border:1px solid ${cl.brd};color:${cl.cor};">${quoted.replace(/</g,'&lt;')} <span style="opacity:.5;font-size:9px;">×</span></span>`;
  }).join('');
}
function repTermosLista() {
  // Prioridade: termos_tags (campo unificado) → termos (legado) → categorias separadas
  let fonte = (repAnchors.termos_tags || repAnchors.termos || '').trim();
  if (!fonte) fonte = ['programas','campanhas','slogans','apelidos','produtos'].map(k => repAnchors[k] || '').filter(Boolean).join('; ');
  return fonte.split(/[;\n]+/).map(s => s.trim()).filter(Boolean).map(repQuoteTermo).filter((v,i,a) => a.indexOf(v) === i);
}
function repTodosTermos() { return repTermosLista().join('; '); }
function repCopiarTermosTags() {
  // Copia o campo termos_tags formatado (1024 chars, igual ao campo do Reputaition)
  const raw = (repAnchors.termos_tags || '').trim();
  const formatted = raw.split(/;|\n/).map(s=>s.trim()).filter(Boolean).map(repQuoteTermo).join('; ');
  if (!formatted) { showToastSafe('⚠️ Campo "Termos (tags)" vazio.'); return; }
  const len = formatted.length;
  const aviso = len > 1024 ? ` ⚠️ ${len}/1024 — o Reputaition aceita até 1024 chars por marca.` : '';
  navigator.clipboard.writeText(formatted)
    .then(() => showToastSafe(`📋 ${repTermosLista().length} termos copiados (${len} chars).${aviso}`))
    .catch(() => showToastSafe('❌ Não foi possível copiar.'));
}
function repCopiarTermos() { repCopiarTermosTags(); }
function repAtualizarContadorTags() {
  const el = document.getElementById('repCountTags'); if (!el) return;
  const raw = (repAnchors.termos_tags || '');
  const formatted = raw.split(/;|\n/).map(s=>s.trim()).filter(Boolean).map(repQuoteTermo).join('; ');
  const len = formatted.length; const over = len > 1024;
  el.textContent = `${len}/1024 caracteres${over ? ' ⚠️' : ''}`;
  el.style.color = over ? 'var(--red)' : 'var(--text-muted)';
  // Atualiza chips em tempo real
  const chips = document.getElementById('repTagsChips');
  if (chips) chips.innerHTML = repChipsPreview(raw);
}
function repCatNormalizado(key) {
  return (repAnchors[key] || '').split(/[;\n]+/).map(s => s.trim()).filter(Boolean).map(repQuoteTermo).filter((v,i,a) => a.indexOf(v) === i).join('; ');
}
function repCopiarCategoria(key, rotulo) {
  const t = repCatNormalizado(key);
  if (!t) { showToastSafe(`⚠️ "${rotulo}" está vazio.`); return; }
  const aviso = t.length > 200 ? ` ⚠️ ${t.length}/200 — divida em mais de uma adição.` : '';
  navigator.clipboard.writeText(t).then(() => showToastSafe(`📋 "${rotulo}" copiado.${aviso}`), () => showToastSafe('❌ Não foi possível copiar.'));
}
function repAtualizarContador(key) {
  const el = document.getElementById('repCount_' + key); if (!el) return;
  const len = repCatNormalizado(key).length; const over = len > 200;
  el.textContent = `${len}/200 caracteres${over ? ' ⚠️' : ''}`;
  el.style.color = over ? 'var(--red)' : 'var(--text-muted)';
}
function repCopiarSimples(key, rotulo) {
  const v = (repAnchors[key]||'').split(/[;\n]+/).map(s=>s.trim()).filter(Boolean).join('; ');
  if (!v) { showToastSafe('⚠️ Campo vazio.'); return; }
  navigator.clipboard.writeText(v).then(() => showToastSafe(`📋 Copiado para "${rotulo}".`), () => showToastSafe('❌ Não foi possível copiar.'));
}
function repListaAdd(lista, modelo) {
  if (!Array.isArray(repAnchors[lista])) repAnchors[lista] = [];
  repAnchors[lista].push({ ...modelo });
  localStorage.setItem('rep_anchors', JSON.stringify(repAnchors));
  renderReputaition();
}
function repListaDel(lista, i) {
  if (Array.isArray(repAnchors[lista])) repAnchors[lista].splice(i, 1);
  localStorage.setItem('rep_anchors', JSON.stringify(repAnchors));
  renderReputaition();
}
function repListaSet(lista, i, campo, valor) {
  if (Array.isArray(repAnchors[lista]) && repAnchors[lista][i]) {
    repAnchors[lista][i][campo] = valor;
    localStorage.setItem('rep_anchors', JSON.stringify(repAnchors));
  }
}

// ════════════════════════════════════════════════════════════
// TESTAR TEMAS — 5 classificações por tema (ideia Sabrina)
// ════════════════════════════════════════════════════════════
let ttState = { temaIdx: 0, casos: {} };
function ttGetCasos(idx) { if (!ttState.casos[idx]) ttState.casos[idx] = []; return ttState.casos[idx]; }
function ttIrTema(idx) {
  const total = (Array.isArray(repAnchors.temas) ? repAnchors.temas : []).length;
  ttState.temaIdx = Math.max(0, Math.min(total - 1, idx));
  renderReputaition();
}
function ttAdicionarCaso(idx) {
  const inp = document.getElementById('ttTextoInput');
  const texto = (inp?.value || '').trim();
  if (!texto) { showToastSafe('⚠️ Digite ou cole um texto de teste.'); return; }
  const casos = ttGetCasos(idx);
  if (casos.length >= 5) { showToastSafe('⚠️ Já há 5 casos para este tema. Avance para o próximo ou remova um.'); return; }
  casos.push({ texto, correto: null });
  if (inp) inp.value = '';
  renderReputaition();
}
function ttMarcarCaso(temaIdx, casoIdx, correto) {
  const casos = ttGetCasos(temaIdx);
  if (casos[casoIdx]) casos[casoIdx].correto = correto;
  renderReputaition();
}
function ttRemoverCaso(temaIdx, casoIdx) {
  ttGetCasos(temaIdx).splice(casoIdx, 1);
  renderReputaition();
}
function ttCopiarPrompt(temaIdx) {
  const tema = (repAnchors.temas || [])[temaIdx];
  if (!tema) return;
  const casos = ttGetCasos(temaIdx);
  if (!casos.length) { showToastSafe('⚠️ Adicione ao menos 1 caso antes de gerar o prompt.'); return; }
  const erros = casos.filter(c => c.correto === false);
  const casosStr = casos.map((c, i) => `[${i+1}] ${c.texto}`).join('\n\n');
  const errosStr = erros.length
    ? '\n\nCASOS COM PROBLEMA (tema identificado quando não deveria, ou vice-versa):\n' + erros.map(c => `- "${c.texto.slice(0,200)}"`).join('\n') : '';
  const prompt = `Você está revisando as premissas do tema "${tema.nome}" (grupo: ${tema.grupo || '—'}) em um sistema de classificação de menções.

PREMISSAS ATUAIS
================
IDENTIFICAR o tema quando:
${(tema.prem_identificar || '(não definidas)').trim()}

NÃO identificar o tema quando:
${(tema.prem_nao_identificar || '(não definidas)').trim()}

CASOS DE TESTE
==============
${casosStr}${errosStr}

TAREFA
======
${erros.length
  ? 'Reescreva as premissas para corrigir os erros acima, mantendo o que funciona. Seja específico o suficiente para que a IA não confunda os casos.'
  : 'As premissas parecem corretas para estes casos. Sugira melhorias ou edge cases que possam falhar.'}

Responda APENAS um JSON válido, sem markdown:
{"prem_identificar":"","prem_nao_identificar":""}`;
  navigator.clipboard.writeText(prompt)
    .then(() => showToastSafe('📋 Prompt copiado! Cole na IA e traga o JSON.'))
    .catch(() => showToastSafe('❌ Não foi possível copiar.'));
}
function ttAplicarResposta(temaIdx) {
  const raw = (document.getElementById('ttJson_'+temaIdx)?.value || '').trim();
  if (!raw) { showToastSafe('⚠️ Cole o JSON da IA.'); return; }
  try {
    let cleaned = raw.replace(/```json\s*/gi,'').replace(/```\s*/g,'').trim();
    const m = cleaned.match(/\{[\s\S]*\}/);
    if (!m) throw new Error('JSON não encontrado.');
    const sug = JSON.parse(m[0]);
    const tema = repAnchors.temas[temaIdx];
    if (!tema) throw new Error('Tema não encontrado.');
    if (sug.prem_identificar !== undefined) tema.prem_identificar = sug.prem_identificar;
    if (sug.prem_nao_identificar !== undefined) tema.prem_nao_identificar = sug.prem_nao_identificar;
    localStorage.setItem('rep_anchors', JSON.stringify(repAnchors));
    showToastSafe(`✅ Premissas de "${tema.nome}" atualizadas!`);
    renderReputaition();
  } catch(e) { showToastSafe('❌ ' + e.message); }
}
function ttRenderPasso() {
  const temas = Array.isArray(repAnchors.temas) ? repAnchors.temas : [];
  if (!temas.length) {
    return `<div style="padding:16px;background:rgba(255,170,40,0.07);border:1px solid rgba(255,170,40,0.25);border-radius:var(--r-md);font-size:12px;color:var(--orange-2);">
      ⚠️ Nenhum tema configurado ainda. Volte ao passo <strong>Temas Monitorados</strong> e adicione ao menos um tema.
      <div style="margin-top:10px;"><button class="tbtn tbtn-primary" style="font-size:11px;padding:6px 14px;" onclick="repIrPasso(${REP_PASSOS.findIndex(p=>p.id==='temas')})">← Voltar para Temas</button></div>
    </div>`;
  }
  const idx = ttState.temaIdx;
  const tema = temas[idx];
  const casos = ttGetCasos(idx);
  const totalOk = casos.filter(c => c.correto === true).length;
  const totalErro = casos.filter(c => c.correto === false).length;
  const totalPend = casos.filter(c => c.correto === null).length;

  // Barra de temas com indicador de progresso
  const navTemas = temas.map((t, i) => {
    const c = ttGetCasos(i);
    const ok = c.filter(x => x.correto === true).length;
    const err = c.filter(x => x.correto === false).length;
    const cor = i===idx ? 'var(--orange-2)' : err > 0 ? '#ff6b6b' : ok===5 ? '#66dd88' : 'var(--text-muted)';
    const bg = i===idx ? 'hsla(var(--theme-h),90%,50%,0.10)' : 'transparent';
    const brd = i===idx ? 'hsla(var(--theme-h),90%,50%,0.35)' : 'rgba(255,255,255,0.10)';
    return `<button onclick="ttIrTema(${i})" style="padding:5px 10px;border-radius:var(--r-sm);border:1px solid ${brd};background:${bg};color:${cor};font-size:11px;font-family:inherit;cursor:pointer;white-space:nowrap;display:flex;align-items:center;gap:5px;">${err>0?'❌':ok===5?'✅':'○'} ${(t.nome||'Tema '+(i+1)).replace(/</g,'&lt;')} <span style="font-size:10px;opacity:.7;">${c.length}/5</span></button>`;
  }).join('');

  // Cards de casos
  const casosHTML = casos.map((c, ci) => {
    const cor = c.correto===true ? '#66dd88' : c.correto===false ? '#ff6b6b' : 'rgba(255,255,255,0.12)';
    return `<div style="border:1px solid ${cor};border-radius:var(--r-md);padding:10px 12px;margin-bottom:8px;background:rgba(255,255,255,0.02);">
      <div style="display:flex;gap:8px;align-items:flex-start;">
        <div style="flex:1;font-size:11px;color:var(--text-secondary);line-height:1.55;">${c.texto.replace(/</g,'&lt;')}</div>
        <div style="display:flex;flex-direction:column;gap:4px;flex-shrink:0;">
          <button onclick="ttMarcarCaso(${idx},${ci},true)" style="padding:3px 10px;border-radius:var(--r-sm);border:1px solid rgba(102,221,136,${c.correto===true?'0.6':'0.25'});background:rgba(102,221,136,${c.correto===true?'0.20':'0.05'});color:#66dd88;font-size:10px;font-family:inherit;cursor:pointer;" title="O tema foi identificado corretamente">✅ Identificou</button>
          <button onclick="ttMarcarCaso(${idx},${ci},false)" style="padding:3px 10px;border-radius:var(--r-sm);border:1px solid rgba(255,107,107,${c.correto===false?'0.6':'0.25'});background:rgba(255,107,107,${c.correto===false?'0.20':'0.05'});color:#ff6b6b;font-size:10px;font-family:inherit;cursor:pointer;" title="O tema não foi identificado (ou foi identificado quando não devia)">❌ Não identificou</button>
          <button onclick="ttRemoverCaso(${idx},${ci})" style="padding:3px 8px;border-radius:var(--r-sm);border:1px solid rgba(255,255,255,0.10);background:transparent;color:var(--text-muted);font-size:10px;font-family:inherit;cursor:pointer;">🗑</button>
        </div>
      </div>
    </div>`;
  }).join('');

  const statusMsg = totalErro > 0
    ? `<span style="color:#ff6b6b;">⚠️ ${totalErro} caso(s) com problema — refine abaixo.</span>`
    : totalOk===5 ? `<span style="color:#66dd88;">✅ 5/5 corretos!</span>`
    : `<span style="color:var(--text-muted);">${casos.length}/5 · ${totalOk} corretos · ${totalPend} pendentes</span>`;

  return `
    <p style="font-size:12px;color:var(--text-secondary);line-height:1.7;margin-bottom:14px;">
      Teste as premissas de cada tema com <strong>5 publicações reais</strong> (ou hipotéticas). Marque se o tema foi identificado corretamente — o HUB gera um prompt para a IA refinar as premissas com base nos erros.
    </p>
    <div style="font-size:11px;font-weight:700;color:var(--text-muted);text-transform:uppercase;letter-spacing:.4px;margin-bottom:8px;">Temas (${temas.length})</div>
    <div style="display:flex;gap:6px;flex-wrap:wrap;margin-bottom:20px;">${navTemas}</div>

    <div style="background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.09);border-radius:var(--r-lg);padding:16px 18px;margin-bottom:14px;">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:6px;">
        <div style="font-size:14px;font-weight:700;color:var(--orange-2);">${(tema.nome||'Tema sem nome').replace(/</g,'&lt;')}</div>
        ${tema.grupo ? `<span style="font-size:10px;color:var(--text-muted);">Grupo: ${tema.grupo}</span>` : ''}
      </div>
      <div style="font-size:10px;color:var(--text-muted);margin-bottom:14px;line-height:1.55;background:rgba(0,0,0,0.15);border-radius:var(--r-sm);padding:8px 10px;">
        <strong>Identificar quando:</strong> ${(tema.prem_identificar||'(não definido)').replace(/\n/g,' · ').replace(/</g,'&lt;')}<br>
        <strong>Não identificar quando:</strong> ${(tema.prem_nao_identificar||'(não definido)').replace(/\n/g,' · ').replace(/</g,'&lt;')}
      </div>
      <div style="font-size:11px;font-weight:600;color:var(--text-primary);margin-bottom:8px;">Casos de teste &nbsp;&nbsp;${statusMsg}</div>
      ${casosHTML || `<div style="font-size:11px;color:var(--text-muted);padding:6px 0;">Nenhum caso adicionado ainda.</div>`}
      ${casos.length < 5 ? `
      <div style="display:flex;gap:8px;margin-top:10px;">
        <textarea id="ttTextoInput" class="config-textarea" style="flex:1;height:64px;" placeholder="Cole ou escreva uma publicação de teste — este texto seria sobre o tema '${(tema.nome||'').replace(/'/g,"\\'")}' ?"></textarea>
        <button class="tbtn tbtn-primary" style="font-size:11px;padding:8px 14px;align-self:flex-end;white-space:nowrap;" onclick="ttAdicionarCaso(${idx})">+ Adicionar</button>
      </div>` : `<div style="font-size:11px;color:#66dd88;margin-top:8px;">5/5 casos adicionados.</div>`}
    </div>

    ${casos.length > 0 ? `
    <div style="background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.09);border-radius:var(--r-lg);padding:16px 18px;">
      <div style="font-size:12px;font-weight:700;color:var(--text-primary);margin-bottom:6px;">Refinar premissas com base nos testes</div>
      <div style="font-size:11px;color:var(--text-muted);margin-bottom:10px;">Copie o prompt, cole na IA, traga o JSON e aplique.</div>
      <div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:10px;">
        <button class="tbtn" style="font-size:11px;padding:7px 14px;" onclick="ttCopiarPrompt(${idx})">📋 Copiar prompt de refinamento</button>
        ${idx < temas.length-1 ? `<button class="tbtn" style="font-size:11px;padding:7px 14px;color:#66dd88;border-color:rgba(102,221,136,0.3);" onclick="ttIrTema(${idx+1})">→ Próximo tema</button>` : `<button class="tbtn" style="font-size:11px;padding:7px 14px;color:#66dd88;border-color:rgba(102,221,136,0.3);" onclick="repIrPasso(REP_PASSOS.findIndex(p=>p.id==='prompt'))">→ Ir para Premissas de Polaridade</button>`}
      </div>
      <textarea id="ttJson_${idx}" class="config-textarea" style="height:64px;font-family:monospace;font-size:11px;" placeholder='{"prem_identificar":"…","prem_nao_identificar":"…"}'></textarea>
      <button class="tbtn tbtn-primary" style="font-size:11px;padding:6px 14px;margin-top:8px;" onclick="ttAplicarResposta(${idx})">✅ Aplicar premissas refinadas</button>
    </div>` : ''}
  `;
}

const REP_CANAIS_SECOM = [
  {nome:'INSTAGRAM',url:'',peso:'5',tipo:'ONLINE',tier:''}, {nome:'FACEBOOK',url:'',peso:'4',tipo:'ONLINE',tier:''},
  {nome:'YOUTUBE',url:'',peso:'3',tipo:'ONLINE',tier:''}, {nome:'TWITTER',url:'',peso:'4',tipo:'ONLINE',tier:''},
  {nome:'LINKEDIN',url:'',peso:'5',tipo:'ONLINE',tier:''}, {nome:'BLOGS',url:'',peso:'2.5',tipo:'ONLINE',tier:''},
  {nome:'COMENTARIOS NO YOUTUBE',url:'',peso:'2',tipo:'ONLINE',tier:''}, {nome:'COMENTARIOS NO FACEBOOK',url:'',peso:'2',tipo:'ONLINE',tier:''},
  {nome:'COMENTARIOS NO LINKEDIN',url:'',peso:'2',tipo:'ONLINE',tier:''}, {nome:'COMENTARIOS NO INSTAGRAM',url:'',peso:'2',tipo:'ONLINE',tier:''},
];
function repCanaisCarregarSecom() {
  const nomesExistentes = new Set(repAnchors.canais.map(c => (c.nome||'').toUpperCase().trim()));
  const novos = REP_CANAIS_SECOM.filter(c => !nomesExistentes.has(c.nome));
  if (!novos.length) { showToastSafe('⚠️ Canais SECOM já estão na lista.'); return; }
  repAnchors.canais = [...repAnchors.canais, ...novos];
  localStorage.setItem('rep_anchors', JSON.stringify(repAnchors));
  renderReputaition();
  showToastSafe(`✅ ${novos.length} canais padrão SECOM adicionados.`);
}
function repCanaisExportarXLSX() {
  if (!repAnchors.canais.length) { showToastSafe('⚠️ Nenhum canal para exportar.'); return; }
  const cols = ['Nome do veículo', 'Tipo de Mídia', 'TIER', 'Peso'];
  const rows = repAnchors.canais.map(c => [c.nome||'', c.tipo||'', c.tier||'', c.peso||'']);
  const wb = XLSX.utils.book_new();
  const ws = XLSX.utils.aoa_to_sheet([cols, ...rows]);
  ws['!cols'] = [40,20,10,10].map(w => ({ wch: w }));
  XLSX.utils.book_append_sheet(wb, ws, 'Canais');
  const nome = (repAnchors.nome || 'cliente').replace(/[^a-z0-9]+/gi,'_').toLowerCase();
  XLSX.writeFile(wb, `canais_${nome}_${new Date().toISOString().slice(0,10)}.xlsx`);
  showToastSafe(`⬇ ${rows.length} canais exportados — importe o .xlsx no Reputaition.`);
}

function repCamposVazios() {
  const faltas = [];
  if (!repTodosTermos()) faltas.push('Marcas → Termos de Detecção (preencha ao menos uma categoria)');
  if (!(repAnchors.foco_cliente_rs||repAnchors.foco_cliente_imp||repAnchors.foco_cliente||'').trim()) faltas.push('Config. Prompt → Foco Cliente (RS ou Imprensa)');
  if (!(repAnchors.prem_positivo||'').trim())     faltas.push('Config. Prompt → Premissas POSITIVO');
  if (!(repAnchors.prem_negativo||'').trim())     faltas.push('Config. Prompt → Premissas NEGATIVO');
  if (!(repAnchors.prem_favoravel||'').trim())    faltas.push('Config. Prompt → Premissas FAVORÁVEL');
  if (!(repAnchors.prem_desfavoravel||'').trim()) faltas.push('Config. Prompt → Premissas DESFAVORÁVEL');
  return faltas;
}
function repSalvarId() {
  const raw = document.getElementById('rep_url')?.value || '';
  const id = repExtrairId(raw);
  if (!id) { showToastSafe('❌ Não encontrei um ID de empresa válido nessa URL.'); return; }
  repAnchors.empresa_id = id;
  localStorage.setItem('rep_anchors', JSON.stringify(repAnchors));
  showToastSafe(`✅ Empresa vinculada! ID: ${id.slice(0,8)}…`);
  renderReputaition();
}
function repPersistir() {
  repSync();
  showToastSafe('💾 Configuração salva neste navegador.');
}
function repAbrirCadastro() { window.open(`${REP_BASE_URL}/#/empresas`, '_blank'); }
function repAbrirUploads() {
  if (!repAnchors.empresa_id) { showToastSafe('⚠️ Vincule a empresa primeiro (cole a URL).'); return; }
  window.open(`${REP_BASE_URL}/#/empresas/${repAnchors.empresa_id}/uploads`, '_blank');
}

// ── Exporta a amostra para o NotebookLM (CSV — base local não costuma ser tão grande) ──
async function exportarBaseNotebookLM(nomeBase) {
  if (!repDB.length) { showToastSafe('⚠️ Importe uma base primeiro (Ekklesia Social ou Press).'); return; }
  const cols = ['canal','data','titulo','conteudo'];
  const head = ['Canal','Data','Titulo','Conteudo'];
  const nome = (nomeBase || 'base').replace(/[^a-z0-9]+/gi,'_').toLowerCase();
  const hoje = new Date().toISOString().slice(0,10);
  const linhas = [head.join(';')];
  repDB.forEach(r => { linhas.push(cols.map(c => _csvCell(r[c])).join(';')); });
  const csv = '\uFEFF' + linhas.join('\n');
  const blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob); a.download = `notebooklm_${nome}_${hoje}.csv`;
  document.body.appendChild(a); a.click(); a.remove(); URL.revokeObjectURL(a.href);
  showToastSafe(`⬇ CSV com ${repDB.length.toLocaleString('pt-BR')} publicações — suba no NotebookLM como fonte.`);
}
function repExportarCSV() { exportarBaseNotebookLM(repAnchors.nome); }

function repPerguntaNotebookLM() {
  const nomeCliente = (repAnchors.nome || 'o cliente').trim();
  return `Você é um analista de social listening configurando a classificação de "${nomeCliente}". Com base nas fontes anexadas (CSV de publicações reais), gere a configuração. Baseie-se SÓ nas fontes; não invente.

DOIS TIPOS DE CAMPO:
1) TERMOS (listas curtas separadas por ";", multi-palavra entre aspas, sem @ nem URL): programas, campanhas, slogans, apelidos, produtos, foco_cliente, foco_concorrente, termos_* (hashtags/expressões que fixam polaridade). Os campos pub_* são SÓ nomes de perfis, pessoas ou veículos específicos (ex.: "Perfil Oficial"; "Jornalista X") — NUNCA descrições como "consumidores satisfeitos"; vazio se não houver.
2) REGRAS/PREMISSAS (frases completas, uma por linha — NUNCA nomes soltos como "${nomeCliente}"): regras_globais, logica_etapa1, logica_etapa2, prem_* e premissas de temas/mensagens. Dê contexto para a IA classificar sozinha (quem é ${nomeCliente}, como decidir cada polaridade, ambiguidades, homônimos). 2-5 frases cada.

mensagens_chave (2-4): mensagem (título) + premissas (quando aplicar) + prem_exclusao (quando não). temas (4-8): nome, grupo, prem_identificar (até 5) e prem_nao_identificar (até 5). grupos_temas 3-6 (nome+peso 1-5). porta_vozes até 6. tipos_pub só extras (senão []).

Responda APENAS um JSON válido, sem markdown:
{"programas":"","campanhas":"","slogans":"","apelidos":"","produtos":"","foco_cliente":"","foco_concorrente":"","regras_globais":"","logica_etapa1":"","logica_etapa2":"","pub_positivo":"","termos_positivo":"","prem_positivo":"","pub_negativo":"","termos_negativo":"","prem_negativo":"","pub_favoravel":"","termos_favoravel":"","prem_favoravel":"","pub_desfavoravel":"","termos_desfavoravel":"","prem_desfavoravel":"","prem_neutro":"","mensagens_chave":[{"mensagem":"","premissas":"","prem_exclusao":""}],"grupos_temas":[{"nome":"","peso":"1"}],"temas":[{"nome":"","grupo":"","prem_identificar":"","prem_nao_identificar":""}],"porta_vozes":[{"nome":"","variacoes":""}],"tipos_pub":[{"nome":"","peso":"1","min":"","max":""}]}`;
}
function repPromptBriefing() {
  const nomeCliente = (repAnchors.nome || '[nome do cliente]').trim();
  let blocoBase = '';
  if (repDB.length) {
    const amostra = repDB.filter(r => (r.titulo || r.conteudo)).slice(0, 50)
      .map((r, i) => `[${i+1}] ${((r.titulo||'') + ' — ' + (r.conteudo||'')).slice(0, 200).replace(/\n/g,' ').trim()}`).join('\n');
    blocoBase = `\n\nCONTEXTO — JÁ TENHO UMA BASE DE MENÇÕES PROCESSADA SOBRE ESTE CLIENTE.\nAbaixo, uma amostra de ${Math.min(repDB.length,50)} de ${repDB.length} publicações reais. Use-a para já sugerir anchors que você identificar e para fazer perguntas mais certeiras. Não invente além do que o briefing e a amostra sustentam.\n\nAMOSTRA:\n${amostra}`;
  }
  return `Você é um consultor de monitoramento de mídia me ajudando a cadastrar um novo cliente numa ferramenta de social listening. O cliente é: ${nomeCliente}.

Tenho o briefing do cliente em mãos (vou colar a seguir, ou responder suas perguntas). Seu objetivo é me ajudar a preencher os "anchors de detecção de citação no título": termos que identificam quando o cliente é mencionado.

Conduza uma breve entrevista, uma pergunta por vez, cobrindo:
1. Programas e iniciativas oficiais do cliente
2. Campanhas publicitárias em andamento ou recentes
3. Slogans e bordões da marca
4. Apelidos e nomes comuns pelos quais o cliente é conhecido
5. Produtos e serviços principais
6. O que torna uma menção POSITIVA, NEGATIVA ou NEUTRA, e o que a torna FAVORÁVEL ou DESFAVORÁVEL ao cliente (premissas de classificação)
7. Quais termos indicam que a menção é de fato sobre o cliente (foco no cliente)

Faça perguntas objetivas, sugira exemplos quando eu não souber, e me ajude a não esquecer variações (siglas, nomes informais).${blocoBase}

REGRAS PARA O JSON FINAL:
- Termos curtos separados por "; ". NÃO inclua @handles, URLs ou nomes de usuário de redes sociais.
- "apelidos" = formas abreviadas/informais do nome em texto corrido (sem @), não o perfil da rede.
- Premissas: uma regra por linha, objetivas.
- Categoria sem evidência = string vazia.

Quando tivermos coberto tudo, finalize devolvendo APENAS um JSON válido, sem markdown, neste formato:
{"termos":"","foco_cliente":"","foco_concorrente":"","regras_globais":"","logica_etapa1":"","logica_etapa2":"","pub_positivo":"","termos_positivo":"","prem_positivo":"","pub_negativo":"","termos_negativo":"","prem_negativo":"","pub_favoravel":"","termos_favoravel":"","prem_favoravel":"","pub_desfavoravel":"","termos_desfavoravel":"","prem_desfavoravel":"","prem_neutro":"","mensagens_chave":[{"mensagem":"","premissas":"","prem_exclusao":""}],"grupos_temas":[{"nome":"","peso":"1"}],"temas":[{"nome":"","grupo":"","prem_identificar":"","prem_nao_identificar":""}],"porta_vozes":[{"nome":"","variacoes":""}],"tipos_pub":[{"nome":"","peso":"1","min":"","max":""}]}
Em "termos", junte produtos, slogans, campanhas, programas e apelidos, separados por "; ". As 5 premissas são obrigatórias. Para as listas (mensagens-chave, grupos, temas, porta-vozes, tipos de publicadores), sugira itens com base no que conversamos e na amostra. Pode começar fazendo a primeira pergunta.`;
}
function repCopiarBriefing() { navigator.clipboard.writeText(repPromptBriefing()).then(() => showToastSafe('📋 Prompt de briefing copiado! Cole na sua IA e converse.'), () => showToastSafe('❌ Não foi possível copiar.')); }
function repCopiarPergunta() { navigator.clipboard.writeText(repPerguntaNotebookLM()).then(() => showToastSafe('📋 Pergunta copiada! Cole no chat do NotebookLM.'), () => showToastSafe('❌ Não foi possível copiar.')); }

function repAplicarResposta() {
  const raw = (document.getElementById('rep_ia_resp')?.value || '').trim();
  if (!raw) { showToastSafe('⚠️ Cole o JSON da IA.'); return; }
  try {
    let cleaned = raw.replace(/```json\s*/gi,'').replace(/```\s*/g,'').trim();
    const m = cleaned.match(/\{[\s\S]*\}/);
    if (!m) throw new Error('JSON não encontrado na resposta.');
    const sug = JSON.parse(m[0]);
    let n = 0;
    Object.keys(sug).forEach(k => {
      if (typeof sug[k] === 'string' && sug[k].trim()) { repAnchors[k] = sug[k].trim(); n++; }
      else if (Array.isArray(sug[k]) && sug[k].length) { repAnchors[k] = sug[k]; n++; }
    });
    localStorage.setItem('rep_anchors', JSON.stringify(repAnchors));
    showToastSafe(`✅ ${n} campo(s) preenchido(s) pela IA!`);
    renderReputaition();
  } catch(e) {
    showToastSafe('❌ ' + e.message);
  }
}

// ── Conversor: repDB → planilha no formato exato de entrada do Reputation ──
const EKKLESIA_TO_REP_COLS = [
  'Canal','Link','Data','Autor ID','Seguidores/Inscritos','Título','Conteúdo','Genero','Idioma','ID Plat',
  'Curtidas/Gostei','Não Gostei','Amei','Haha','Uau','Triste','Raiva','Outras Reações','Total de Reações',
  'Comentários','Compartilhamentos','Visualizações','Autor Nome','Autor Link','Minutagem',
];
const REP_CANAL_MAP = {
  'facebook':'Facebook','instagram':'Instagram','x':'Twitter','twitter':'Twitter','youtube':'YouTube',
  'tiktok':'TikTok','linkedin':'LinkedIn','reddit':'Reddit','bluesky':'Bluesky','threads':'Threads',
  'reclameaqui':'ReclameAqui','reclame aqui':'ReclameAqui','portais':'Portais','portal':'Portais','news':'Portais',
};
const REP_IDIOMA_MAP = { 'pt':'Português','pt-br':'Português','português':'Português','portugues':'Português','en':'Inglês','es':'Espanhol' };
function repSafeStr(str) {
  return (str || '').toString().replace(/_x000d_/gi,'').replace(/\r\n?/g,'\n')
    .replace(/[\u0000-\u0008\u000B\u000C\u000E-\u001F]/g,'').replace(/\n{3,}/g,'\n\n').trim().substring(0,32700);
}
function repExportarAmostraXLSX(tamanho) {
  if (!repDB.length) { showToastSafe('⚠️ Importe uma base primeiro.'); return; }
  const n = Math.max(1, Math.min(repDB.length, tamanho || repDB.length));
  const amostra = repDB.slice(0, n);
  const aoa = [EKKLESIA_TO_REP_COLS];
  amostra.forEach(r => {
    let dataFmt = '', horaFmt = '';
    if (r.data) { try { const d = new Date(r.data); if (!isNaN(d)) { dataFmt = d.toLocaleDateString('pt-BR'); horaFmt = d.toLocaleTimeString('pt-BR',{hour:'2-digit',minute:'2-digit',second:'2-digit'}); } } catch(e){} }
    const canalKey = (r.canal || '').toLowerCase().trim();
    const canalRep = REP_CANAL_MAP[canalKey] || (r.canal || '').split(' ').map(w => w.charAt(0).toUpperCase() + w.slice(1).toLowerCase()).join(' ');
    const idiomaKey = (r.idioma || '').toLowerCase().trim();
    const idiomaRep = REP_IDIOMA_MAP[idiomaKey] || (r.idioma ? r.idioma : 'Português');
    let totalReacoes = '';
    if (r.curtidas != null || r.outras_reacoes != null) totalReacoes = (r.curtidas||0) + (r.outras_reacoes||0);
    aoa.push([
      canalRep, repSafeStr(r.link_publicacao), `${dataFmt} ${horaFmt}`.trim(), repSafeStr(r.nome_publicador),
      (() => { const sg = Number(r.seguidores); return Number.isFinite(sg) && sg > 0 ? sg : 0; })(),
      repSafeStr(r.titulo), repSafeStr(r.conteudo), repSafeStr(r.genero), idiomaRep, repSafeStr(r.id_publicacao),
      r.curtidas ?? '', '', '', '', '', '', '', r.outras_reacoes ?? '', totalReacoes,
      r.comentarios ?? '', r.compartilhamentos ?? '', r.visualizacoes ?? '', repSafeStr(r.nome_publicador), repSafeStr(r.link_publicador), '',
    ]);
  });
  const wb = XLSX.utils.book_new();
  const ws = XLSX.utils.aoa_to_sheet(aoa);
  XLSX.utils.book_append_sheet(wb, ws, 'Para Reputation');
  const nomeOut = `reputaition_amostra_${(repAnchors.nome||'cliente').replace(/[^a-z0-9]+/gi,'_').toLowerCase()}_${new Date().toISOString().substring(0,10)}.xlsx`;
  XLSX.writeFile(wb, nomeOut);
  showToastSafe(`✅ ${amostra.length.toLocaleString('pt-BR')} registros exportados — importe no Reputaition.`);
}

// ── Conversor: planilha classificada do Reputation → repDB ──
function parseRowsReputation(rows) {
  if (!rows.length) return [];
  const hdr = Object.keys(rows[0]);
  const normStr = s => String(s||'').toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g,'').replace(/[\u200B-\u200D\uFEFF]/g,'').trim();
  const idx = {}; hdr.forEach(h => { idx[normStr(h)] = h; });
  const resolve = (...aliases) => { for (const a of aliases) { const k = idx[normStr(a)]; if (k !== undefined) return k; } return null; };
  const K = {
    hora: resolve('Hora do post','hora'), data: resolve('Data da menção','data','Date','date'),
    link: resolve('Link da menção','Link','url','URL'), publicacao: resolve('Publicação','Conteúdo','conteudo','Texto','Content','content','Message','Snippet'),
    publicador: resolve('Publicador','Nome do perfil','Nickname','Autor Nome','Nome','Autor','Author'),
    id: resolve('ID','Resource Id'), titulo: resolve('Título','Title'),
    polaridade: resolve('Polaridade','Sentimento','Classificação','Avaliação','Sentiment'),
    canal: resolve('Canal','Rede Social','Rede','Channel','Source'),
    curtidas: resolve('Curtidas','Likes','Curtidas/Gostei'), comentarios: resolve('Comentários','Comments'),
    compartilhamentos: resolve('Compartilhamentos','Shares','Retweets'), visualizacoes: resolve('Visualizações','Views'),
    reacoes: resolve('Reações','Reactions','Outras Reações'), totalInter: resolve('Total Interações','Total de Interações','Total'),
    seguidores: resolve('Seguidores','Followers'), grupo_tema: resolve('GRUPO TEMA','Grupo Tema'),
    tema: resolve('TEMA','Tema'), abordagem: resolve('Abordagem'), tipo_pub: resolve('Tipo Publicador'),
    porta_vozes: resolve('Porta-vozes','Porta vozes'), valorizacao: resolve('Valoração','Valorizacao'),
    cena: resolve('CENA','Cena'),
  };
  const COLUNAS_FIXAS = new Set(Object.values(idx).filter(realKey => Object.values(K).includes(realKey)).map(k => normStr(k)));
  const colsTema = hdr.filter(h => !COLUNAS_FIXAS.has(normStr(h)) && !/^p\.|^justificativas$/i.test(h.trim()));
  const g = (r,key) => { if (!key) return null; const v = r[key]; if (v===undefined||v===null) return null; const s = String(v).trim(); return s===''?null:s; };
  const gf = (r,key) => { const v = r[key]; return (v===undefined||v===null||v==='') ? null : (parseFloat(String(v).replace(/[^\d.\-]/g,'')) || null); };
  const parsed = [];
  for (let i = 0; i < rows.length; i++) {
    const r = rows[i];
    const dataRaw = g(r, K.data), horaRaw = g(r, K.hora);
    let dataISO = null;
    try {
      const dParts = dataRaw && dataRaw.match(/^(\d{2})\/(\d{2})\/(\d{4})$/);
      if (dParts) dataISO = new Date(`${dParts[3]}-${dParts[2]}-${dParts[1]}T${horaRaw||'00:00:00'}`).toISOString();
      else if (dataRaw) { const d = new Date([dataRaw,horaRaw].filter(Boolean).join(' ')); dataISO = isNaN(d) ? parseDateCustom(dataRaw) : d.toISOString(); }
    } catch(e) { dataISO = parseDateCustom(dataRaw); }
    let temaStr = g(r, K.tema) || '';
    if (colsTema.length) {
      const ativos = [];
      for (let j = 0; j < colsTema.length; j++) { const v = r[colsTema[j]]; if (v!==null && v!==undefined && String(v).trim()!=='') ativos.push(String(v).trim()); }
      if (ativos.length) temaStr = ativos.join('; ');
    }
    const obj = {
      fonte: 'reputation', canal: g(r, K.canal), data: dataISO,
      link_publicacao: g(r, K.link), nome_publicador: g(r, K.publicador), id_publicacao: g(r, K.id),
      titulo: g(r, K.titulo), conteudo: g(r, K.publicacao), sentimento: canonSent(g(r, K.polaridade) || ''),
      seguidores: gf(r, K.seguidores), curtidas: gf(r, K.curtidas), comentarios: gf(r, K.comentarios),
      compartilhamentos: gf(r, K.compartilhamentos), visualizacoes: gf(r, K.visualizacoes), outras_reacoes: gf(r, K.reacoes),
      grupo_tema: g(r, K.grupo_tema), tema: temaStr, abordagem: g(r, K.abordagem), tipo_publicador: g(r, K.tipo_pub),
      porta_vozes: g(r, K.porta_vozes), valorizacao: gf(r, K.valorizacao), cena: gf(r, K.cena),
    };
    if (obj.canal || obj.conteudo || obj.data) parsed.push(obj);
  }
  return parsed;
}

function repImportarClassificada() {
  const btn = document.getElementById('repUsarImportBtn');
  const status = document.getElementById('repUsarImportStatus');
  const inp = document.createElement('input');
  inp.type = 'file'; inp.accept = '.csv,.xlsx,.xls';
  inp.onchange = async e => {
    const file = e.target.files[0]; if (!file) return;
    if (btn) { btn.disabled = true; btn.innerHTML = '<span class="spinner"></span> Importando…'; }
    if (status) status.innerHTML = '';
    try {
      const rawRows = await new Promise((res, rej) => {
        const reader = new FileReader();
        reader.onload = ev => { try { const wb = XLSX.read(new Uint8Array(ev.target.result),{type:'array'}); res(XLSX.utils.sheet_to_json(wb.Sheets[wb.SheetNames[0]],{defval:''})); } catch(err) { rej(err); } };
        reader.onerror = rej;
        reader.readAsArrayBuffer(file);
      });
      if (!rawRows.length) throw new Error('Arquivo vazio ou formato não reconhecido.');
      const parsed = parseRowsReputation(rawRows);
      if (!parsed.length) throw new Error('Nenhuma linha mapeada — verifique se é uma exportação do Reputaition com classificações.');
      const antes = repDB.length;
      repDB = mesclarNaRepDB(parsed);
      repSalvarDBSessao();
      const adicionados = repDB.length - antes;
      const grupos = [...new Set(parsed.map(r => r.grupo_tema).filter(Boolean))];
      const temas = [...new Set(parsed.map(r => r.tema).filter(Boolean))];
      if (status) status.innerHTML = `
        <div style="padding:10px 14px;background:rgba(102,221,136,0.09);border:1px solid rgba(102,221,136,0.25);border-radius:var(--r-md);font-size:12px;color:var(--green);">
          ✅ <strong>${adicionados.toLocaleString('pt-BR')}</strong> registros classificados incorporados.
          <br><span style="font-size:10px;color:var(--text-muted);">Total na base local: <strong>${repDB.length.toLocaleString('pt-BR')}</strong>. ${grupos.length} grupos · ${temas.length} temas detectados.</span>
        </div>`;
      showToastSafe(`✅ ${adicionados} registros classificados importados!`);
      renderReputaition();
    } catch(err) {
      console.error(err);
      if (status) status.innerHTML = `<div style="color:var(--red);font-size:11px;">❌ ${err.message}</div>`;
      showToastSafe('❌ ' + err.message);
    } finally {
      if (btn) { btn.disabled = false; btn.innerHTML = '⬆ Importar base classificada do Reputaition'; }
    }
  };
  inp.click();
}

// ── Tabela editável genérica (Mensagem-Chave, Grupos, Canais, Porta-vozes, Pubs) ──
function repTabelaLista(lista, cols, modelo, titulo) {
  const itens = Array.isArray(repAnchors[lista]) ? repAnchors[lista] : [];
  const linhas = itens.map((it, i) => `
    <div style="display:flex;gap:6px;align-items:flex-start;margin-bottom:6px;">
      ${cols.map(c => `
        <div style="flex:${c.w||1};min-width:0;">
          ${c.textarea
            ? `<textarea class="config-textarea" style="height:48px;width:100%;" placeholder="${c.ph||''}" oninput="repListaSet('${lista}',${i},'${c.key}',this.value)">${(it[c.key]||'').replace(/</g,'&lt;')}</textarea>`
            : `<input type="text" class="macro-input" style="width:100%;" placeholder="${c.ph||''}" value="${(it[c.key]||'').replace(/"/g,'&quot;')}" oninput="repListaSet('${lista}',${i},'${c.key}',this.value)">`}
        </div>`).join('')}
      <button class="tbtn" style="font-size:11px;padding:6px 9px;flex-shrink:0;color:var(--red);border-color:rgba(255,82,82,0.2);" onclick="repListaDel('${lista}',${i})" title="Remover">✕</button>
    </div>`).join('');
  return `
    <div style="display:flex;gap:6px;margin-bottom:6px;padding:0 33px 0 0;">
      ${cols.map(c => `<div style="flex:${c.w||1};font-size:10px;font-weight:600;color:var(--text-muted);text-transform:uppercase;letter-spacing:.3px;">${c.label}</div>`).join('')}
    </div>
    ${linhas || `<div style="font-size:11px;color:var(--text-muted);padding:10px 0;">Nenhum item ainda. A IA preenche no passo 1, ou adicione manualmente.</div>`}
    <button class="tbtn" style="font-size:11px;padding:6px 14px;margin-top:6px;" onclick='repListaAdd("${lista}", ${JSON.stringify(modelo)})'>+ Adicionar ${titulo}</button>`;
}

// ════════════════════════════════════════════════════════════
// REFINAR PREMISSAS COM AMOSTRA — calibração autocontida
// ════════════════════════════════════════════════════════════
const POLS_OPCOES = ['Positivo','Negativo','Favorável','Desfavorável','Neutro'];
let refCalib = JSON.parse(sessionStorage.getItem('rep_ref_calib') || '{}');
function refSalvarCalib() { sessionStorage.setItem('rep_ref_calib', JSON.stringify(refCalib)); }
function refCalibToggleErro(idx) {
  if (!refCalib[idx]) refCalib[idx] = { errado:true };
  else { refCalib[idx].errado = !refCalib[idx].errado; if (!refCalib[idx].errado) { delete refCalib[idx].correta; delete refCalib[idx].motivo; } }
  refSalvarCalib();
  repMontarCalibracao();
}
function refCalibSet(idx, campo, valor) { if (!refCalib[idx]) refCalib[idx] = { errado:true }; refCalib[idx][campo] = valor; refSalvarCalib(); }

function refAmostraClassificada() {
  return repDB.map((r,idx) => ({ r, idx })).filter(({r}) => r.fonte === 'reputation' && r.sentimento).slice(0, 100);
}

function repRenderCalibracao() {
  const lote = refAmostraClassificada();
  if (!lote.length) return '';
  const erros = Object.values(refCalib).filter(v => v.errado).length;
  const cards = lote.map(({r, idx}) => {
    const cal = refCalib[idx] || {};
    const marcado = !!cal.errado;
    const preview = (r.conteudo || r.titulo || '').slice(0, 220);
    const opts = POLS_OPCOES.map(p => `<option value="${p}" ${cal.correta===p?'selected':''}>${p}</option>`).join('');
    return `
      <div style="border:1px solid ${marcado?'rgba(255,107,107,0.4)':'rgba(255,255,255,0.07)'};border-radius:var(--r-md);padding:10px 12px;margin-bottom:8px;background:${marcado?'rgba(255,107,107,0.05)':'rgba(255,255,255,0.02)'};">
        <div style="display:flex;align-items:flex-start;gap:10px;">
          <label style="display:flex;align-items:center;gap:6px;flex-shrink:0;cursor:pointer;font-size:11px;color:var(--text-muted);margin-top:2px;">
            <input type="checkbox" ${marcado?'checked':''} onchange="refCalibToggleErro(${idx})"> errado
          </label>
          <div style="flex:1;min-width:0;">
            <div style="display:flex;gap:8px;flex-wrap:wrap;align-items:center;margin-bottom:4px;">
              <span style="font-size:9px;color:rgba(255,255,255,0.3);">#${idx+1}</span>
              ${r.canal?`<span style="font-size:9px;padding:1px 6px;border-radius:20px;background:rgba(255,255,255,0.05);color:var(--text-muted);">${r.canal}</span>`:''}
              <span style="font-size:9px;padding:1px 6px;border-radius:20px;background:rgba(136,170,255,0.12);color:#88aaff;">Reputaition: ${r.sentimento||'—'}</span>
            </div>
            <div style="font-size:11px;color:var(--text-secondary);line-height:1.55;">${preview.replace(/</g,'&lt;')}${(r.conteudo||'').length>220?'<span style="color:var(--orange-2);">… ver mais</span>':''}</div>
            ${marcado ? `
            <div style="display:flex;gap:8px;flex-wrap:wrap;margin-top:8px;align-items:center;">
              <span style="font-size:10px;color:var(--text-muted);">Correto:</span>
              <select class="macro-input" style="width:auto;font-size:11px;padding:4px 8px;" onchange="refCalibSet(${idx},'correta',this.value)"><option value="">— polaridade —</option>${opts}</select>
              <input type="text" class="macro-input" style="flex:1;min-width:160px;font-size:11px;padding:4px 8px;" placeholder="por que está errado? (ex.: é elogio, não reclamação)" value="${(cal.motivo||'').replace(/"/g,'&quot;')}" oninput="refCalibSet(${idx},'motivo',this.value)">
            </div>` : ''}
          </div>
        </div>
      </div>`;
  }).join('');
  return `
    <div style="background:var(--card-bg,rgba(255,255,255,0.02));border:1px solid var(--border,rgba(255,255,255,0.08));border-radius:var(--r-lg);padding:18px;margin-bottom:16px;">
      <div style="font-size:13px;font-weight:600;color:var(--text-primary);margin-bottom:6px;">③ Calibrar premissas <span style="font-size:10px;font-weight:500;color:var(--text-muted);">(opcional, recomendado para amostra)</span></div>
      <div style="font-size:11px;color:var(--text-secondary);line-height:1.6;margin-bottom:12px;">
        Revise as classificações do lote, marque as que vieram <strong style="color:#ff6b6b;">erradas</strong> e informe a classificação correta. O HUB gera um prompt com esses erros para a IA <strong>reescrever as premissas</strong>.
      </div>
      <div style="max-height:420px;overflow-y:auto;margin-bottom:12px;">${cards}</div>
      <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;">
        <button class="tbtn tbtn-primary" style="font-size:12px;padding:8px 16px;" onclick="repGerarPromptCorrecao()">🔧 Gerar prompt de correção (${erros} erro${erros!==1?'s':''})</button>
        <button class="tbtn" style="font-size:11px;padding:6px 12px;" onclick="refCalib={};refSalvarCalib();repMontarCalibracao();">Limpar marcações</button>
        <span style="font-size:11px;color:var(--text-muted);">${erros} de ${lote.length} marcados como errados</span>
      </div>
      <div id="refCalibStatus" style="margin-top:10px;"></div>
    </div>`;
}

function repGerarPromptCorrecao() {
  const errosEntries = Object.entries(refCalib).filter(([,v]) => v.errado && v.correta);
  const semCorreta = Object.entries(refCalib).filter(([,v]) => v.errado && !v.correta).length;
  if (!errosEntries.length) {
    const st = document.getElementById('refCalibStatus');
    if (st) st.innerHTML = `<div style="color:var(--orange-2);font-size:11px;">Marque ao menos um post como errado e selecione a polaridade correta${semCorreta?' (há erros sem polaridade correta definida)':''}.</div>`;
    return;
  }
  const nomeCliente = (repAnchors.nome || 'o cliente').trim();
  const premAtuais = [
    ['POSITIVO', repAnchors.prem_positivo], ['NEGATIVO', repAnchors.prem_negativo],
    ['FAVORÁVEL', repAnchors.prem_favoravel], ['DESFAVORÁVEL', repAnchors.prem_desfavoravel],
  ].map(([k,v]) => `${k}:\n${(v||'(vazio)').trim()}`).join('\n\n');
  const casos = errosEntries.map(([idx, v], i) => {
    const r = repDB[idx] || {};
    const texto = (r.conteudo || r.titulo || '').slice(0, 300).replace(/\n/g,' ');
    return `ERRO ${i+1}:\nTexto: "${texto}"\nReputaition classificou: ${r.sentimento||'—'}\nCorreto: ${v.correta}\nMotivo: ${v.motivo||'(não informado)'}`;
  }).join('\n\n');
  const prompt = `Você ajustou a classificação de sentimento/polaridade de "${nomeCliente}", mas alguns posts vieram errados. Abaixo estão as PREMISSAS ATUAIS e os ERROS encontrados numa amostra. Reescreva as premissas para que esses erros não se repitam, mantendo o que já funciona.

PREMISSAS ATUAIS
================
${premAtuais}

ERROS ENCONTRADOS NA AMOSTRA
============================
${casos}

TAREFA
======
Analise por que a IA errou cada caso e reescreva as premissas (frases completas e objetivas, uma por linha) para corrigir. Seja específico o suficiente para a IA distinguir os casos confundidos. Mantenha premissas boas que já existiam.

Responda APENAS um JSON válido, sem markdown:
{"prem_positivo":"","prem_negativo":"","prem_favoravel":"","prem_desfavoravel":"","prem_neutro":""}`;
  navigator.clipboard.writeText(prompt).then(() => {
    const st = document.getElementById('refCalibStatus');
    if (st) st.innerHTML = `<div style="padding:10px 14px;background:rgba(102,221,136,0.09);border:1px solid rgba(102,221,136,0.25);border-radius:var(--r-md);font-size:11px;color:var(--green);line-height:1.6;">📋 Prompt de correção copiado (${errosEntries.length} erro${errosEntries.length!==1?'s':''}). Cole na IA, traga o JSON e aplique abaixo.</div>`;
    showToastSafe('📋 Prompt de correção copiado!');
  }, () => showToastSafe('❌ Não foi possível copiar.'));
}

function repAplicarPremissasRefinadas() {
  const raw = (document.getElementById('repRefinarJson')?.value || '').trim();
  const st = document.getElementById('repRefinarStatus');
  if (!raw) { showToastSafe('⚠️ Cole o JSON de premissas'); return; }
  try {
    let cleaned = raw.replace(/```json\s*/gi,'').replace(/```\s*/g,'').trim();
    const m = cleaned.match(/\{[\s\S]*\}/);
    if (!m) throw new Error('JSON não encontrado');
    const sug = JSON.parse(m[0]);
    const campos = ['prem_positivo','prem_negativo','prem_favoravel','prem_desfavoravel','prem_neutro'];
    let n = 0;
    campos.forEach(k => { if (sug[k] !== undefined) { repAnchors[k] = sug[k]; n++; } });
    localStorage.setItem('rep_anchors', JSON.stringify(repAnchors));
    if (st) st.textContent = `✅ ${n} premissas aplicadas no Reputaition.`;
    showToastSafe('✅ Premissas refinadas aplicadas!');
    setTimeout(() => renderReputaition(), 600);
  } catch(e) {
    if (st) st.innerHTML = `<div style="color:var(--red);">❌ ${e.message}</div>`;
  }
}

function repMontarCalibracao() {
  const slot = document.getElementById('repRefinarCalibracao');
  if (!slot) return;
  slot.innerHTML = repRenderCalibracao();
}

// ════════════════════════════════════════════════════════════
// RENDER PRINCIPAL DO WIZARD
// ════════════════════════════════════════════════════════════
function renderReputaition() {
  const tem = !!repAnchors.empresa_id;
  const passo = REP_PASSOS[repPasso];
  const temNome = !!(repAnchors.nome||'').trim();
  let corpo = '';

  if (passo.id === 'dados') {
    corpo = `
      <p style="font-size:12px;color:var(--text-secondary);line-height:1.7;margin-bottom:16px;">
        Comece definindo o cliente. Preencha o nome e deixe a IA sugerir os dados a partir de uma base importada ou do briefing do cliente.
      </p>

      <div style="background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08);border-radius:var(--r-md);padding:14px 16px;margin-bottom:16px;">
        <div style="font-size:11px;font-weight:700;color:var(--text-primary);text-transform:uppercase;letter-spacing:.4px;margin-bottom:4px;">📥 Base de publicações desta sessão — ${repDB.length.toLocaleString('pt-BR')} registros</div>
        <div style="font-size:10px;color:var(--text-muted);margin-bottom:10px;line-height:1.5;">Abra o Ekklesia para fazer o upload e processar a base lá — depois volte e clique em "Puxar".</div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:8px;">
          <div style="border:1px solid rgba(255,255,255,0.09);border-radius:var(--r-md);padding:10px 12px;">
            <div style="font-size:10px;font-weight:700;color:var(--orange-2);text-transform:uppercase;letter-spacing:.4px;margin-bottom:6px;">🏛️ Ekklesia Social</div>
            <div style="display:flex;flex-direction:column;gap:5px;">
              <button class="tbtn tbtn-primary" style="font-size:11px;padding:6px 12px;justify-content:center;" onclick="abrirEkklesiaModal('social')">⬆ Subir base aqui</button>
              <button id="repImportSocialBtn" class="tbtn" style="font-size:11px;padding:6px 12px;justify-content:center;" onclick="repPuxarEkklesiaSocial()">⬇ Puxar base já processada</button>
            </div>
          </div>
          <div style="border:1px solid rgba(255,255,255,0.09);border-radius:var(--r-md);padding:10px 12px;">
            <div style="font-size:10px;font-weight:700;color:#88aaff;text-transform:uppercase;letter-spacing:.4px;margin-bottom:6px;">📰 Ekklesia Press</div>
            <div style="display:flex;flex-direction:column;gap:5px;">
              <button class="tbtn" style="font-size:11px;padding:6px 12px;justify-content:center;color:#88aaff;border-color:rgba(136,170,255,0.3);background:rgba(136,170,255,0.06);" onclick="abrirEkklesiaModal('press')">⬆ Subir base aqui</button>
              <button id="repImportPressBtn" class="tbtn" style="font-size:11px;padding:6px 12px;justify-content:center;" onclick="repAbrirImportacaoPress()">⬇ Importar Export Geral</button>
            </div>
          </div>
        </div>
        ${repDB.length ? `<button class="tbtn" style="font-size:11px;padding:5px 12px;color:var(--red);border-color:rgba(255,82,82,0.2);" onclick="repLimparBase()">🗑 Limpar base (${repDB.length.toLocaleString('pt-BR')} registros)</button>` : ''}
      </div>

      <div style="margin-bottom:16px;">
        <label class="field-label">Nome da empresa / cliente *</label>
        <input id="rep_nome" type="text" class="macro-input" style="width:100%;" placeholder="Ex: MISCI"
               value="${(repAnchors.nome||'').replace(/"/g,'&quot;')}" oninput="repSync(); repToggleGate();">
      </div>
      <div id="repEntryBox" style="background:hsla(var(--theme-h),90%,50%,0.05);border:1px solid hsla(var(--theme-h),90%,50%,0.18);border-radius:var(--r-md);padding:16px;opacity:${temNome?'1':'0.5'};pointer-events:${temNome?'auto':'none'};transition:opacity .2s;">
        <div style="font-size:12px;font-weight:600;color:var(--text-primary);margin-bottom:10px;">${temNome ? 'Como montar os dados?' : '🔒 Digite o nome do cliente para habilitar'}</div>
        <div style="display:flex;gap:8px;flex-wrap:wrap;">
          <button class="tbtn ${repFonte==='base'?'tbtn-primary':''}" style="font-size:11px;padding:8px 16px;" onclick="repEscolherFonte('base')" ${repDB.length?'':'disabled title="Importe uma base acima primeiro"'}>📊 Usar a base importada</button>
          <button class="tbtn ${repFonte==='briefing'?'tbtn-primary':''}" style="font-size:11px;padding:8px 16px;" onclick="repEscolherFonte('briefing')">💬 Começar pelo briefing</button>
          <button class="tbtn ${repFonte==='zero'?'tbtn-primary':''}" style="font-size:11px;padding:8px 16px;" onclick="repEscolherFonte('zero')">✍️ Preencher do zero</button>
        </div>
        ${repFonte==='base' ? `
          <div style="margin-top:14px;padding-top:14px;border-top:1px dashed rgba(255,255,255,0.1);">
            <div style="font-size:11px;color:var(--text-secondary);line-height:1.6;margin-bottom:10px;">Baixe a base, suba como fonte no NotebookLM, copie a pergunta e traga o JSON.</div>
            <div style="display:flex;gap:8px;flex-wrap:wrap;">
              <button class="tbtn" style="font-size:11px;padding:6px 14px;color:#88aaff;border-color:rgba(136,170,255,0.3);background:rgba(136,170,255,0.08);" onclick="repExportarCSV()">⬇ Baixar base (CSV)</button>
              <button class="tbtn" style="font-size:11px;padding:6px 14px;" onclick="repCopiarPergunta()">📋 Copiar pergunta</button>
            </div>
          </div>` : ''}
        ${repFonte==='briefing' ? `
          <div style="margin-top:14px;padding-top:14px;border-top:1px dashed rgba(255,255,255,0.1);">
            <div style="font-size:11px;color:var(--text-secondary);line-height:1.6;margin-bottom:10px;">Copie o prompt, cole na sua IA e responda as perguntas dela.${repDB.length?` <span style="color:#d88aff;">A base (${repDB.length.toLocaleString('pt-BR')} pubs) é embutida.</span>`:''}</div>
            <button class="tbtn" style="font-size:11px;padding:6px 14px;color:#d88aff;border-color:rgba(216,138,255,0.35);background:rgba(216,138,255,0.1);" onclick="repCopiarBriefing()">📋 Copiar prompt de briefing</button>
          </div>` : ''}
        ${repFonte==='zero' ? `
          <div style="margin-top:14px;padding-top:14px;border-top:1px dashed rgba(255,255,255,0.1);">
            <div style="font-size:11px;color:var(--text-secondary);line-height:1.6;margin-bottom:10px;">Preencha os campos manualmente nos próximos passos, ou suba uma planilha bruta de qualquer ferramenta (Stilingue, Brandwatch, Sprinklr…) para usar como base de referência.</div>
            <div style="display:flex;gap:8px;flex-wrap:wrap;align-items:center;">
              <button class="tbtn tbtn-primary" style="font-size:11px;padding:7px 16px;" onclick="repIrPasso(1)">→ Ir para Detecção de Citação</button>
              <button class="tbtn" style="font-size:11px;padding:7px 14px;color:#66dd88;border-color:rgba(102,221,136,0.3);background:rgba(102,221,136,0.06);" onclick="repImportarAvulso()">⬆ Subir planilha avulsa</button>
            </div>
            <div id="repAvulsoStatus" style="margin-top:8px;font-size:11px;color:var(--text-muted);">${repDB.length ? `✅ ${repDB.length.toLocaleString('pt-BR')} registros já carregados.` : ''}</div>
          </div>` : ''}
        ${repFonte ? `
          <div style="margin-top:14px;">
            <div style="font-size:10px;font-weight:600;color:var(--text-muted);text-transform:uppercase;letter-spacing:.4px;margin-bottom:6px;">Cole o JSON da IA</div>
            <textarea id="rep_ia_resp" class="config-textarea" style="height:64px;" placeholder="Cole aqui o JSON da IA…"></textarea>
            <button class="tbtn tbtn-primary" style="font-size:11px;padding:6px 16px;margin-top:8px;" onclick="repAplicarResposta()">✓ Aplicar resposta</button>
          </div>` : ''}
      </div>
      <div style="margin-top:16px;display:flex;align-items:center;gap:8px;">
        <button class="tbtn" style="font-size:11px;padding:6px 14px;color:#88aaff;border-color:rgba(136,170,255,0.3);background:rgba(136,170,255,0.08);" onclick="repAbrirCadastro()">↗ Abrir cadastro no Reputaition</button>
        <span style="font-size:11px;color:var(--text-muted);">Crie a empresa e, na mesma tela, preencha os termos de detecção (próximo passo).</span>
      </div>
      <div style="display:flex;gap:24px;flex-wrap:wrap;margin-top:12px;">
        <label style="display:flex;align-items:center;gap:8px;font-size:12px;color:var(--text-secondary);cursor:pointer;">
          <input id="rep_cadastrar_concorrentes" type="checkbox" ${repAnchors.cadastrar_concorrentes?'checked':''} onchange="repSync()"> Cadastrar concorrentes
        </label>
        <label style="display:flex;align-items:center;gap:8px;font-size:12px;color:var(--text-secondary);cursor:pointer;">
          <input id="rep_gov" type="checkbox" ${repAnchors.gov?'checked':''} onchange="repSync()"> É instituição governamental
        </label>
      </div>`;
  }

  else if (passo.id === 'marcas') {
    // ── Campo de categoria (programas, campanhas etc.) ───────────────
    const campoCat = (c) => {
      const val = (repAnchors[c.key] || '');
      const normalizado = repCatNormalizado(c.key);
      const len = normalizado.length; const over = len > 200;
      const termos = val.split(/[;\n]+/).map(s=>s.trim()).filter(Boolean);
      const previewTermos = termos.length ? termos.map(t => {
        const quoted = repQuoteTermo(t);
        const cl = repClassTermo(quoted);
        if (!cl) return '';
        return `<span style="display:inline-block;margin:2px 3px 2px 0;padding:1px 7px;border-radius:20px;font-size:10px;background:${cl.bg};border:1px solid ${cl.brd};color:${cl.cor};">${quoted.replace(/</g,'&lt;')}</span>`;
      }).join('') : '';
      return `
        <div style="margin-bottom:14px;">
          <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:4px;">
            <label style="font-size:11px;font-weight:600;color:var(--text-muted);">${c.label}</label>
            <button class="tbtn" style="font-size:10px;padding:3px 9px;" onclick="repCopiarCategoria('${c.key}','${c.label}')">📋 Copiar categoria</button>
          </div>
          <textarea id="rep_${c.key}" class="config-textarea" style="height:52px;" placeholder="${c.hint}" oninput="repSync();repAtualizarContador('${c.key}')">${val.replace(/</g,'&lt;')}</textarea>
          ${previewTermos ? `<div style="margin-top:5px;line-height:1.4;">${previewTermos}</div>` : ''}
          <div style="display:flex;justify-content:space-between;align-items:center;margin-top:3px;gap:8px;">
            <span style="font-size:10px;color:var(--text-muted);">Separe por ; — multi-palavra entre aspas automático.</span>
            <span id="repCount_${c.key}" style="font-size:10px;color:${over?'var(--red)':'var(--text-muted)'};white-space:nowrap;">${len}/200 chars${over?' ⚠️':''}</span>
          </div>
        </div>`;
    };

    // ── Preview de chips completo do campo termos_tags ───────────────
    const tagsVal = (repAnchors.termos_tags || '');
    const tagsFormatted = tagsVal.split(/;|\n/).map(s=>s.trim()).filter(Boolean).map(repQuoteTermo).join('; ');
    const tagsLen = tagsFormatted.length;
    const tagsOver = tagsLen > 1024;

    // ── Sugestão automática a partir das categorias ──────────────────
    const sugeridos = ['programas','campanhas','slogans','apelidos','produtos']
      .map(k => repAnchors[k] || '').filter(Boolean).join('; ');
    const temSugestao = sugeridos.trim() && sugeridos.trim() !== tagsVal.trim();

    corpo = `
      <p style="font-size:12px;color:var(--text-secondary);line-height:1.7;margin-bottom:14px;">
        Em <strong>Marcas da Empresa → Atualizar Marca</strong> no Reputaition. Preencha o <strong>Nome da Marca</strong> e os <strong>Termos (tags)</strong> — campo único que aceita até 1024 chars, separados por ponto e vírgula.
      </p>

      <!-- Nome da Marca -->
      <div style="margin-bottom:18px;padding:14px 16px;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.09);border-radius:var(--r-md);">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:6px;">
          <label class="field-label" style="margin-bottom:0;">Nome da Marca <span style="color:var(--orange-2);">*</span></label>
          <button class="tbtn" style="font-size:10px;padding:3px 9px;" onclick="navigator.clipboard.writeText((repAnchors.nome_marca||repAnchors.nome||'').trim()).then(()=>showToastSafe('📋 Nome da marca copiado.'))">📋 Copiar</button>
        </div>
        <div style="font-size:10px;color:var(--text-muted);margin-bottom:6px;">Nome exibido no painel do Reputaition. Geralmente o nome curto da marca (ex: SECOM, MISCI).</div>
        <input id="rep_nome_marca" type="text" class="macro-input" style="width:100%;"
          placeholder="Ex: SECOM · MISCI · Petrobras"
          value="${(repAnchors.nome_marca||repAnchors.nome||'').replace(/"/g,'&quot;')}"
          oninput="repSync()">
      </div>

      <!-- Termos (tags) — campo principal -->
      <div style="margin-bottom:18px;padding:14px 16px;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.09);border-radius:var(--r-md);">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:4px;">
          <label class="field-label" style="margin-bottom:0;">Termos (tags) <span style="color:var(--orange-2);">*</span></label>
          <div style="display:flex;gap:6px;">
            ${temSugestao ? `<button class="tbtn" style="font-size:10px;padding:3px 9px;color:#66dd88;border-color:rgba(102,221,136,0.3);" onclick="repAnchors.termos_tags=(repAnchors.termos_tags?repAnchors.termos_tags+'; ':'')+${JSON.stringify(sugeridos)};localStorage.setItem('rep_anchors',JSON.stringify(repAnchors));renderReputaition()">+ Sugerir das categorias</button>` : ''}
            <button class="tbtn tbtn-primary" style="font-size:10px;padding:3px 9px;" onclick="repCopiarTermosTags()">📋 Copiar tudo</button>
          </div>
        </div>
        <div style="font-size:10px;color:var(--text-muted);margin-bottom:8px;">Campo único do Reputaition (até 1024 chars). Aceita termos simples, <code style="background:rgba(136,170,255,0.15);padding:0 4px;border-radius:3px;">@handles</code>, <code style="background:rgba(216,138,255,0.15);padding:0 4px;border-radius:3px;">OR / AND / NOT</code>, e frases entre aspas. Separe por <strong>;</strong>.</div>
        <textarea id="rep_termos_tags" class="config-textarea" style="height:80px;" 
          placeholder='Ex: SECOM; "Secretaria de Comunicação"; @secomc; "Governo Federal"; "Plano Safra" OR "Programa Safra"; "primeira-dama" OR "Janja"'
          oninput="repSync();repAtualizarContadorTags()">${tagsVal.replace(/</g,'&lt;')}</textarea>
        <!-- Chips preview estilo Reputaition -->
        <div id="repTagsChips" style="margin-top:8px;min-height:10px;line-height:1.6;">${repChipsPreview(tagsVal)}</div>
        <div style="display:flex;justify-content:space-between;align-items:center;margin-top:4px;">
          <div style="font-size:10px;color:var(--text-muted);display:flex;gap:8px;flex-wrap:wrap;">
            <span>🟡 multi-palavra</span><span style="color:#88aaff;">● handle @</span><span style="color:#d88aff;">● booleano OR/AND/NOT</span><span style="color:var(--text-muted);">● simples</span>
          </div>
          <span id="repCountTags" style="font-size:10px;color:${tagsOver?'var(--red)':'var(--text-muted)'};white-space:nowrap;">${tagsLen}/1024 chars${tagsOver?' ⚠️':''}</span>
        </div>
      </div>

      <!-- Categorias de apoio (colapsáveis) -->
      <details style="margin-bottom:8px;">
        <summary style="font-size:11px;font-weight:600;color:var(--text-muted);cursor:pointer;padding:8px 0;user-select:none;">📂 Categorias de apoio (opcional — organiza antes de montar os termos)</summary>
        <div style="padding-top:12px;">
          <div style="font-size:11px;color:var(--text-secondary);line-height:1.6;margin-bottom:12px;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08);border-radius:var(--r-md);padding:10px 12px;">
            💡 Preencha aqui para organizar, depois clique <strong>"+ Sugerir das categorias"</strong> acima para juntar no campo de Termos (tags).
          </div>
          ${REP_CAMPOS.map(campoCat).join('')}
        </div>
      </details>`;
  }

  else if (passo.id === 'msg') {
    corpo = `
      <p style="font-size:12px;color:var(--text-secondary);line-height:1.7;margin-bottom:14px;">
        Cada linha abaixo vira <strong>uma mensagem separada</strong> no Reputaition — cada uma com suas próprias premissas.
      </p>
      <div style="background:rgba(136,170,255,0.06);border:1px solid rgba(136,170,255,0.18);border-radius:var(--r-md);padding:10px 12px;margin-bottom:14px;font-size:11px;color:var(--text-secondary);line-height:1.6;">
        💡 <strong>Mensagem</strong> = título da mensagem-chave. <strong>Premissas</strong> (obrigatório) = quando classificar sob essa mensagem. <strong>Premissas de Exclusão</strong> (opcional) = quando não.
      </div>
      ${repTabelaLista('mensagens_chave',
        [{key:'mensagem',label:'Mensagem',ph:'título da mensagem-chave',w:2,textarea:true},
         {key:'premissas',label:'Premissas * (incluir)',ph:'quando aplicar — uma por linha ou ;',w:3,textarea:true},
         {key:'prem_exclusao',label:'Premissas de Exclusão',ph:'quando NÃO aplicar (opcional)',w:3,textarea:true}],
        {mensagem:'',premissas:'',prem_exclusao:''}, 'mensagem')}`;
  }

  else if (passo.id === 'grupos') {
    corpo = `
      <p style="font-size:12px;color:var(--text-secondary);line-height:1.7;margin-bottom:16px;">
        Em <strong>Grupos de Temas Monitorados → Editar</strong>. Nome do grupo + Peso (1-5).
      </p>
      ${repTabelaLista('grupos_temas',
        [{key:'nome',label:'Nome do grupo',ph:'ex: Institucional',w:3}, {key:'peso',label:'Peso',ph:'1-5',w:1}],
        {nome:'',peso:'1'}, 'grupo')}`;
  }

  else if (passo.id === 'temas') {
    const temasItens = Array.isArray(repAnchors.temas) ? repAnchors.temas : [];
    const temasCards = temasItens.map((it, i) => {
      const nIdent = (it.prem_identificar||'').split(/[;\n]+/).map(s=>s.trim()).filter(Boolean).length;
      const nExcl = (it.prem_nao_identificar||'').split(/[;\n]+/).map(s=>s.trim()).filter(Boolean).length;
      return `
      <div style="border:1px solid rgba(255,255,255,0.08);border-radius:var(--r-md);padding:12px;margin-bottom:8px;background:rgba(255,255,255,0.02);">
        <div style="display:flex;gap:6px;margin-bottom:10px;align-items:flex-start;">
          <div style="flex:3;min-width:0;">
            <div style="font-size:10px;font-weight:600;color:var(--text-muted);text-transform:uppercase;letter-spacing:.3px;margin-bottom:3px;">Nome do tema</div>
            <input type="text" class="macro-input" style="width:100%;" placeholder="ex: Lançamento" value="${(it.nome||'').replace(/"/g,'&quot;')}" oninput="repListaSet('temas',${i},'nome',this.value)">
          </div>
          <div style="flex:3;min-width:0;">
            <div style="font-size:10px;font-weight:600;color:var(--text-muted);text-transform:uppercase;letter-spacing:.3px;margin-bottom:3px;">Grupo</div>
            <input type="text" class="macro-input" style="width:100%;" placeholder="grupo temático" value="${(it.grupo||'').replace(/"/g,'&quot;')}" oninput="repListaSet('temas',${i},'grupo',this.value)">
          </div>
          <button class="tbtn" style="font-size:11px;padding:6px 9px;flex-shrink:0;color:var(--red);border-color:rgba(255,82,82,0.2);margin-top:16px;" onclick="repListaDel('temas',${i})" title="Remover">✕</button>
        </div>
        <div style="margin-bottom:10px;">
          <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:3px;">
            <div style="font-size:10px;font-weight:600;color:#66dd88;text-transform:uppercase;letter-spacing:.3px;">✅ Identificar TEMA quando</div>
            <span style="font-size:10px;color:${nIdent>5?'var(--red)':'var(--text-muted)'};">${nIdent}/5 premissas${nIdent>5?' ⚠️':''}</span>
          </div>
          <textarea class="config-textarea" style="height:90px;width:100%;font-size:11px;line-height:1.6;" placeholder="Uma premissa por linha (ou separadas por ;). Máx. 5." oninput="repListaSet('temas',${i},'prem_identificar',this.value)">${(it.prem_identificar||'').replace(/</g,'&lt;')}</textarea>
        </div>
        <div>
          <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:3px;">
            <div style="font-size:10px;font-weight:600;color:#ff6b6b;text-transform:uppercase;letter-spacing:.3px;">🚫 Não identificar TEMA quando</div>
            <span style="font-size:10px;color:${nExcl>5?'var(--red)':'var(--text-muted)'};">${nExcl}/5 premissas${nExcl>5?' ⚠️':''}</span>
          </div>
          <textarea class="config-textarea" style="height:90px;width:100%;font-size:11px;line-height:1.6;" placeholder="Opcional, mas ajuda. Máx. 5." oninput="repListaSet('temas',${i},'prem_nao_identificar',this.value)">${(it.prem_nao_identificar||'').replace(/</g,'&lt;')}</textarea>
        </div>
      </div>`;
    }).join('');
    corpo = `
      <p style="font-size:12px;color:var(--text-secondary);line-height:1.7;margin-bottom:10px;">
        Em <strong>Temas Monitorados → Editar</strong>. Foco aqui é <strong>nome</strong>, <strong>grupo</strong> e <strong>premissas</strong>.
      </p>
      ${temasCards || `<div style="font-size:11px;color:var(--text-muted);padding:10px 0;">Nenhum tema ainda. A IA preenche no passo 1, ou adicione manualmente.</div>`}
      <button class="tbtn" style="font-size:11px;padding:6px 14px;margin-top:6px;" onclick='repListaAdd("temas", ${JSON.stringify({nome:"",grupo:"",prem_identificar:"",prem_nao_identificar:""})})'>+ Adicionar tema</button>`;
  }

  else if (passo.id === 'testar_temas') {
    corpo = ttRenderPasso();
  }

  else if (passo.id === 'porta') {
    corpo = `
      <p style="font-size:12px;color:var(--text-secondary);line-height:1.7;margin-bottom:10px;">Em <strong>Porta-vozes → Editar</strong>.</p>
      ${repTabelaLista('porta_vozes', [{key:'nome',label:'Nome',ph:'nome do porta-voz',w:2}, {key:'variacoes',label:'Variações (;)',ph:'apelido; nome alternativo',w:2}], {nome:'',variacoes:''}, 'porta-voz')}`;
  }

  else if (passo.id === 'pubs') {
    const REP_PUB_PADRAO = [
      { nome:'DEFAULT', peso:'0', min:'', max:'' }, { nome:'USUARIO COMUM', peso:'1', min:'0', max:'1999' },
      { nome:'INFLUENCIADOR PEQUENO', peso:'2.5', min:'', max:'' }, { nome:'INFLUENCIADOR MICRO', peso:'1.5', min:'2000', max:'9999' },
      { nome:'INFLUENCIADOR BAIXO', peso:'2', min:'10000', max:'49999' }, { nome:'INFLUENCIADOR MEDIO', peso:'2.5', min:'50000', max:'99999' },
      { nome:'INFLUENCIADOR ALTO', peso:'3', min:'100000', max:'999999' }, { nome:'INFLUENCIADOR MACRO', peso:'4', min:'1000000', max:'4999999' },
      { nome:'MEGAINFLUENCIADOR OU CELEBRIDADE', peso:'5', min:'5000000', max:'' }, { nome:'JORNALISTA', peso:'3', min:'', max:'' }, { nome:'POLITICOS', peso:'5', min:'', max:'' },
    ];
    const padraoLinhas = REP_PUB_PADRAO.map(p => `
      <tr><td style="padding:6px 10px;font-size:11px;color:var(--text-primary);border-top:1px solid rgba(255,255,255,0.05);">${p.nome}</td>
      <td style="padding:6px 10px;font-size:11px;color:var(--text-secondary);text-align:center;border-top:1px solid rgba(255,255,255,0.05);">${p.peso}</td>
      <td style="padding:6px 10px;font-size:11px;color:var(--text-secondary);text-align:right;border-top:1px solid rgba(255,255,255,0.05);">${p.min ? (+p.min).toLocaleString('pt-BR') : '—'}</td>
      <td style="padding:6px 10px;font-size:11px;color:var(--text-secondary);text-align:right;border-top:1px solid rgba(255,255,255,0.05);">${p.max ? (+p.max).toLocaleString('pt-BR') : '—'}</td></tr>`).join('');
    corpo = `
      <p style="font-size:12px;color:var(--text-secondary);line-height:1.7;margin-bottom:10px;">Em <strong>Tipos de Publicadores → Editar</strong>.</p>
      <div style="background:rgba(102,221,136,0.06);border:1px solid rgba(102,221,136,0.18);border-radius:var(--r-md);padding:10px 12px;margin-bottom:14px;font-size:11px;color:var(--text-secondary);line-height:1.6;">
        ✅ <strong>O padrão base abaixo já existe no Reputaition</strong>. Use a tabela abaixo só para tipos <strong>extras</strong> do cliente.
      </div>
      <div style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.4px;color:var(--text-muted);margin-bottom:6px;">Padrão base (referência · read-only)</div>
      <div style="background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08);border-radius:var(--r-md);overflow:hidden;margin-bottom:18px;">
        <table style="width:100%;border-collapse:collapse;"><thead><tr>
          <th style="padding:8px 10px;font-size:10px;font-weight:600;color:var(--text-muted);text-transform:uppercase;letter-spacing:.3px;text-align:left;">Nome</th>
          <th style="padding:8px 10px;font-size:10px;font-weight:600;color:var(--text-muted);text-transform:uppercase;letter-spacing:.3px;text-align:center;">Peso</th>
          <th style="padding:8px 10px;font-size:10px;font-weight:600;color:var(--text-muted);text-transform:uppercase;letter-spacing:.3px;text-align:right;">Mín. seg.</th>
          <th style="padding:8px 10px;font-size:10px;font-weight:600;color:var(--text-muted);text-transform:uppercase;letter-spacing:.3px;text-align:right;">Máx. seg.</th>
        </tr></thead><tbody>${padraoLinhas}</tbody></table>
      </div>
      <div style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.4px;color:var(--text-muted);margin-bottom:6px;">Tipos extras do cliente (editável)</div>
      ${repTabelaLista('tipos_pub', [{key:'nome',label:'Nome',ph:'ex: Mega-influenciador',w:2},{key:'peso',label:'Peso',ph:'1-5',w:1},{key:'min',label:'Mín. seg.',ph:'min',w:1},{key:'max',label:'Máx. seg.',ph:'max',w:1}], {nome:'',peso:'1',min:'',max:''}, 'tipo')}`;
  }

  else if (passo.id === 'canais') {
    corpo = `
      <p style="font-size:12px;color:var(--text-secondary);line-height:1.7;margin-bottom:10px;">Em <strong>Canais Monitorados → Editar</strong>. Monte a lista e exporte o XLSX para importar em lote no Reputaition.</p>
      <div style="background:rgba(255,170,40,0.08);border:1px solid rgba(255,170,40,0.28);border-radius:var(--r-md);padding:10px 12px;margin-bottom:12px;font-size:11px;color:var(--text-secondary);line-height:1.6;">
        ⚠️ <strong>Tipo de mídia, Tier e logos SVG são obrigatórios no Reputaition</strong> — a IA não define tier.
      </div>
      <div style="display:flex;gap:8px;margin-bottom:14px;flex-wrap:wrap;">
        <button class="tbtn" style="font-size:11px;padding:7px 14px;" onclick="repCanaisCarregarSecom()">📋 Carregar padrão SECOM (redes sociais)</button>
        <button class="tbtn" style="font-size:11px;padding:7px 14px;color:#66dd88;border-color:rgba(102,221,136,0.3);" onclick="repCanaisExportarXLSX()" ${repAnchors.canais.length?'':'disabled title="Adicione canais primeiro"'}>⬇ Exportar XLSX para importação</button>
      </div>
      ${repTabelaLista('canais', [{key:'nome',label:'Nome do canal',ph:'ex: Folha de S.Paulo',w:3},{key:'url',label:'URL',ph:'link do canal',w:2},{key:'peso',label:'Peso',ph:'ex: 3',w:1},{key:'tipo',label:'Tipo de mídia',ph:'ONLINE / IMPRESSO',w:2},{key:'tier',label:'Tier',ph:'1–5 / Super',w:1}], {nome:'',url:'',peso:'',tipo:'',tier:''}, 'canal')}`;
  }

  else if (passo.id === 'clip') {
    corpo = `
      <p style="font-size:12px;color:var(--text-secondary);line-height:1.7;margin-bottom:12px;">Em <strong>Clipadoras da Empresa → Editar</strong>.</p>
      <div style="background:rgba(255,170,40,0.08);border:1px solid rgba(255,170,40,0.28);border-radius:var(--r-md);padding:10px 12px;font-size:11px;color:var(--text-secondary);line-height:1.6;">
        ⚠️ <strong>Este passo é integração técnica</strong> — Clipadora, Acrônimo, Chave da API e URL da API. Preencha direto no Reputaition.
      </div>`;
  }

  else if (passo.id === 'prompt') {
    const ta = (k,lbl,obrig,ph,h) => {
      const val = (repAnchors[k]||'');
      const palavras = val.trim() ? val.trim().split(/\s+/).length : 0;
      const pareceRaso = val.trim() && palavras < 6;
      return `
      <div style="margin-bottom:14px;">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:5px;">
          <label class="field-label" style="margin-bottom:0;">${lbl} ${obrig?'<span style="color:var(--orange-2);">*</span>':'<span style="font-size:10px;color:var(--text-muted);">(opcional)</span>'}</label>
          <button class="tbtn" style="font-size:10px;padding:3px 10px;" onclick="repCopiarSimples('${k}','${lbl}')">📋 Copiar</button>
        </div>
        <textarea id="rep_${k}" class="config-textarea" style="height:${h||100}px;line-height:1.6;" placeholder="${ph||'uma regra por linha'}" oninput="repSync()">${val.replace(/</g,'&lt;')}</textarea>
        ${pareceRaso ? `<div style="font-size:10px;color:var(--orange-2);margin-top:4px;">⚠️ Conteúdo curto — descreva uma regra completa em frase, não só um nome.</div>` : ''}
      </div>`;
    };
    const inp = (k,lbl,obrig,hint) => `
      <div style="margin-bottom:14px;">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:5px;">
          <label class="field-label" style="margin-bottom:0;">${lbl} ${obrig?'<span style="color:var(--orange-2);">*</span>':''}</label>
          <button class="tbtn" style="font-size:10px;padding:3px 10px;" onclick="repCopiarSimples('${k}','${lbl}')">📋 Copiar</button>
        </div>
        ${hint ? `<div class="field-hint">${hint}</div>` : ''}
        <input id="rep_${k}" type="text" class="macro-input" style="width:100%;" placeholder="termos separados por ;" value="${(repAnchors[k]||'').replace(/"/g,'&quot;')}" oninput="repSync()">
      </div>`;
    const subt = (t) => `<div style="font-size:11px;font-weight:700;color:var(--orange-2);text-transform:uppercase;letter-spacing:.4px;margin:18px 0 10px;border-top:1px dashed rgba(255,255,255,0.1);padding-top:14px;">${t}</div>`;
    const pubAviso = (kp) => {
      const v = (repAnchors[kp]||'').split(/[;\n]+/).map(x=>x.trim().replace(/^["']|["']$/g,'')).filter(Boolean);
      const suspeitos = v.filter(s => s && (s.split(/\s+/).length > 5 || (s.charAt(0) && s.charAt(0)===s.charAt(0).toLowerCase() && s.charAt(0)!==s.charAt(0).toUpperCase())));
      return suspeitos.length ? `<div style="font-size:10px;color:var(--orange-2);margin-top:4px;">⚠️ Parece descrição, não perfil: ${suspeitos.slice(0,3).map(s=>s.replace(/</g,'&lt;')).join(', ')}${suspeitos.length>3?'…':''}. Mova para Premissas.</div>` : '';
    };
    const polaridade = (cor,nome,kp,kt,kpr) => `
      <div style="border:1px solid rgba(255,255,255,0.08);border-radius:var(--r-md);padding:12px;margin-bottom:12px;">
        <div style="font-size:12px;font-weight:700;color:${cor};margin-bottom:10px;">● ${nome}</div>
        ${inp(kp, 'Publicadores', false, 'Apenas <strong>perfis, pessoas ou veículos específicos</strong> com polaridade conhecida. Separados por <strong>;</strong>. Deixe vazio se não houver.')}
        ${pubAviso(kp)}
        ${inp(kt, 'Termos Proprietários', false, 'Hashtags ou expressões que determinam esta polaridade — separados por <strong>;</strong>.')}
        ${ta(kpr, 'Premissas', true, 'Condições objetivas em frases que definem esta polaridade (uma por linha, máx. 15).')}
      </div>`;
    const opcional = (cor,nome,kp,kt) => `
      <div style="border:1px solid rgba(255,255,255,0.06);border-radius:var(--r-md);padding:12px;margin-bottom:12px;background:rgba(255,255,255,0.01);">
        <div style="display:flex;align-items:center;gap:8px;margin-bottom:10px;">
          <div style="font-size:12px;font-weight:700;color:${cor};">● ${nome}</div>
          <span style="font-size:9px;font-weight:600;color:var(--text-muted);background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.12);border-radius:4px;padding:1px 6px;">OPCIONAL</span>
        </div>
        ${inp(kp, 'Publicadores', false)} ${inp(kt, 'Termos Proprietários', false)}
      </div>`;
    corpo = `
      <p style="font-size:12px;color:var(--text-secondary);line-height:1.7;margin-bottom:8px;">
        Em <strong>Configuração de Prompt → Editar</strong>, na ordem exata do Reputaition. POSITIVO, NEGATIVO, FAVORÁVEL e DESFAVORÁVEL são <strong>obrigatórias</strong> (mín. 1 regra cada). <span style="color:var(--orange-2);">Escreva regras em frases completas e explicativas</span>.
      </p>
      ${subt('Regras de Contexto (opcional)')}
      ${ta('regras_globais','Regras Globais', false, 'Contexto que vale para TODA análise: quem é o cliente, setor, ambiguidades a evitar.', 90)}
      ${subt('Lógica de Classificação e Contexto (opcional)')}
      ${ta('logica_etapa1','Primeira Etapa (positivo, negativo, neutro)', false, 'Critérios para decidir POSITIVO / NEGATIVO / NEUTRO.', 100)}
      ${ta('logica_etapa2','Segunda Etapa (favorável, desfavorável)', false, 'Critérios para FAVORÁVEL / DESFAVORÁVEL à reputação.', 100)}
      ${subt('Configurações de Foco')}
      <div style="background:rgba(136,170,255,0.06);border:1px solid rgba(136,170,255,0.18);border-radius:var(--r-md);padding:10px 12px;margin-bottom:14px;font-size:11px;color:var(--text-secondary);line-height:1.6;">
        💡 <strong>Foco Cliente</strong> são os termos que a IA usa para reconhecer que uma publicação é <em>sobre</em> o cliente.
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:14px;">
        <div>
          <div style="font-size:10px;font-weight:700;color:#66dd88;text-transform:uppercase;letter-spacing:.4px;margin-bottom:6px;">📱 Redes Sociais</div>
          ${inp('foco_cliente_rs','Foco Cliente', true, 'Termos que a IA usa para reconhecer que a publicação é sobre o cliente.')}
          ${inp('foco_concorrente_rs','Foco Concorrente', false, 'Termos dos concorrentes.')}
        </div>
        <div>
          <div style="font-size:10px;font-weight:700;color:#88aaff;text-transform:uppercase;letter-spacing:.4px;margin-bottom:6px;">📰 Imprensa</div>
          ${inp('foco_cliente_imp','Foco Cliente', true, 'Mesma lógica, mas para imprensa: nomes formais, ministérios, programas.')}
          ${inp('foco_concorrente_imp','Foco Concorrente', false, 'Termos dos concorrentes na imprensa.')}
        </div>
      </div>
      ${subt('Premissas por polaridade — Obrigatórias')}
      ${polaridade('#66dd88','POSITIVO','pub_positivo','termos_positivo','prem_positivo')}
      ${polaridade('#ff6b6b','NEGATIVO','pub_negativo','termos_negativo','prem_negativo')}
      ${polaridade('#88ccff','FAVORÁVEL','pub_favoravel','termos_favoravel','prem_favoravel')}
      ${polaridade('#ffaa44','DESFAVORÁVEL','pub_desfavoravel','termos_desfavoravel','prem_desfavoravel')}
      <div style="border:1px solid rgba(255,255,255,0.08);border-radius:var(--r-md);padding:12px;margin-bottom:12px;">
        <div style="font-size:12px;font-weight:700;color:var(--text-secondary);margin-bottom:10px;">● NEUTRO</div>
        ${ta('prem_neutro','Premissas', true, 'uma regra por linha (máx. 15)')}
      </div>
      ${subt('Publicadores e Termos Cruzados — Opcionais')}
      ${opcional('#66dd88 / #88ccff','POSITIVO / FAVORÁVEL','pub_pos_fav','termos_pos_fav')}
      ${opcional('#ff6b6b / #ffaa44','NEGATIVO / DESFAVORÁVEL','pub_neg_des','termos_neg_des')}`;
  }

  else if (passo.id === 'vincular') {
    corpo = `
      <p style="font-size:12px;color:var(--text-secondary);line-height:1.7;margin-bottom:14px;">
        Depois de criar e configurar a empresa no Reputaition, copie a URL dela (da barra do navegador) e cole aqui.
      </p>
      ${(() => { const f = repCamposVazios(); return f.length ? `
        <div style="background:rgba(255,170,40,0.08);border:1px solid rgba(255,170,40,0.28);border-radius:var(--r-md);padding:10px 12px;margin-bottom:12px;font-size:11px;color:var(--text-secondary);line-height:1.6;">
          ⚠️ <strong>Campos obrigatórios ainda vazios</strong>: <ul style="margin:6px 0 0;padding-left:18px;">${f.map(x=>`<li>${x}</li>`).join('')}</ul>
        </div>` : `<div style="background:rgba(102,221,136,0.07);border:1px solid rgba(102,221,136,0.22);border-radius:var(--r-md);padding:8px 12px;margin-bottom:12px;font-size:11px;color:var(--green);">✅ Campos obrigatórios preenchidos.</div>`; })()}
      <label style="font-size:11px;font-weight:600;color:var(--text-muted);text-transform:uppercase;letter-spacing:.4px;display:block;margin-bottom:6px;">URL da empresa no Reputaition</label>
      <div style="display:flex;gap:8px;">
        <input id="rep_url" type="text" class="macro-input" style="flex:1;" placeholder="https://app.reputaition.nexus.fsb.com.br/…#/empresas/…">
        <button class="tbtn tbtn-primary" style="font-size:11px;padding:6px 16px;white-space:nowrap;" onclick="repSalvarId()">Vincular</button>
      </div>
      ${tem ? `<div style="font-size:11px;color:var(--green);margin-top:8px;">✅ Empresa vinculada · ID <code style="background:rgba(0,0,0,0.25);padding:1px 6px;border-radius:4px;">${repAnchors.empresa_id}</code></div>` : ''}`;
  }

  else if (passo.id === 'classificar') {
    const temBase = repDB.length > 0;
    const temPremissas = !!(repAnchors.prem_positivo || repAnchors.prem_negativo);
    const lote = refAmostraClassificada();

    // Monta as premissas consolidadas para o batch
    const premissasConsolidadas = [
      repAnchors.regras_globais, repAnchors.logica_etapa1, repAnchors.logica_etapa2,
      repAnchors.prem_positivo ? 'POSITIVO: ' + repAnchors.prem_positivo : '',
      repAnchors.prem_negativo ? 'NEGATIVO: ' + repAnchors.prem_negativo : '',
      repAnchors.prem_favoravel ? 'FAVORÁVEL: ' + repAnchors.prem_favoravel : '',
      repAnchors.prem_desfavoravel ? 'DESFAVORÁVEL: ' + repAnchors.prem_desfavoravel : '',
      repAnchors.prem_neutro ? 'NEUTRO: ' + repAnchors.prem_neutro : '',
    ].filter(Boolean).join('\n\n');

    corpo = `
      <p style="font-size:12px;color:var(--text-secondary);line-height:1.7;margin-bottom:16px;">
        Classifique uma amostra da base, revise os resultados e refine as premissas — tudo aqui, sem sair da tela.
      </p>

      ${!temBase ? `
      <div style="padding:14px 16px;background:rgba(255,170,68,0.07);border:1px solid rgba(255,170,68,0.25);border-radius:var(--r-md);font-size:12px;color:var(--orange-2);margin-bottom:16px;">
        ⚠ Nenhuma base importada. Volte ao passo <strong>Empresa — Dados</strong> e importe uma base.
        <div style="margin-top:8px;"><button class="tbtn tbtn-primary" style="font-size:11px;padding:6px 14px;" onclick="repIrPasso(0)">← Ir para Dados</button></div>
      </div>` : ''}

      ${!temPremissas ? `
      <div style="padding:14px 16px;background:rgba(255,170,68,0.07);border:1px solid rgba(255,170,68,0.25);border-radius:var(--r-md);font-size:12px;color:var(--orange-2);margin-bottom:16px;">
        ⚠ Premissas de polaridade ainda não configuradas. Volte ao passo <strong>Configuração de Prompt</strong>.
        <div style="margin-top:8px;"><button class="tbtn tbtn-primary" style="font-size:11px;padding:6px 14px;" onclick="repIrPasso(${REP_PASSOS.findIndex(p=>p.id==='prompt')})">← Configurar Premissas</button></div>
      </div>` : ''}

      <!-- ① CLASSIFICAR -->
      <div style="background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.09);border-radius:var(--r-lg);padding:16px 18px;margin-bottom:14px;">
        <div style="font-size:13px;font-weight:700;color:var(--text-primary);margin-bottom:4px;">① Classificar amostra</div>
        <div style="font-size:11px;color:var(--text-muted);margin-bottom:12px;line-height:1.6;">
          O HUB gera um prompt compacto com as premissas embutidas. Cole em qualquer IA (Claude, Gemini, ChatGPT) e traga a resposta.
        </div>
        ${temBase ? `<div id="repBatchContainer"></div>` : `<div style="font-size:11px;color:var(--text-muted);">Importe uma base primeiro.</div>`}
      </div>

      <!-- ② REVISAR CARDS -->
      <div style="background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.09);border-radius:var(--r-lg);padding:16px 18px;margin-bottom:14px;">
        <div style="font-size:13px;font-weight:700;color:var(--text-primary);margin-bottom:4px;">② Revisar classificações</div>
        <div style="font-size:11px;color:var(--text-muted);margin-bottom:12px;line-height:1.6;">
          Marque as que vieram <strong style="color:#ff6b6b;">erradas</strong> e informe a classificação correta. O HUB gera um prompt para a IA reescrever as premissas.
        </div>
        ${lote.length ? `<div id="repRefinarCalibracao"></div>` : `
        <div style="padding:12px 14px;background:rgba(255,255,255,0.02);border:1px solid rgba(255,255,255,0.07);border-radius:var(--r-md);font-size:11px;color:var(--text-muted);">
          As publicações classificadas no passo ① aparecerão aqui para revisão.
        </div>`}
      </div>

      <!-- ③ EDITAR PREMISSAS E RE-RODAR -->
      <div style="background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.09);border-radius:var(--r-lg);padding:16px 18px;">
        <div style="font-size:13px;font-weight:700;color:var(--text-primary);margin-bottom:4px;">③ Refinar premissas</div>
        <div style="font-size:11px;color:var(--text-muted);margin-bottom:12px;line-height:1.6;">
          Cole o JSON da IA com as premissas corrigidas, aplique e rode novamente o classificador — ciclo contínuo na mesma tela.
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:12px;">
          <div>
            <div style="font-size:10px;font-weight:600;color:#66dd88;text-transform:uppercase;letter-spacing:.4px;margin-bottom:4px;">Premissas POSITIVO</div>
            <textarea id="rep_prem_positivo" class="config-textarea" style="height:80px;font-size:11px;" placeholder="uma regra por linha" oninput="repSync()">${(repAnchors.prem_positivo||'').replace(/</g,'&lt;')}</textarea>
          </div>
          <div>
            <div style="font-size:10px;font-weight:600;color:#ff6b6b;text-transform:uppercase;letter-spacing:.4px;margin-bottom:4px;">Premissas NEGATIVO</div>
            <textarea id="rep_prem_negativo" class="config-textarea" style="height:80px;font-size:11px;" placeholder="uma regra por linha" oninput="repSync()">${(repAnchors.prem_negativo||'').replace(/</g,'&lt;')}</textarea>
          </div>
          <div>
            <div style="font-size:10px;font-weight:600;color:#88ccff;text-transform:uppercase;letter-spacing:.4px;margin-bottom:4px;">Premissas FAVORÁVEL</div>
            <textarea id="rep_prem_favoravel" class="config-textarea" style="height:80px;font-size:11px;" placeholder="uma regra por linha" oninput="repSync()">${(repAnchors.prem_favoravel||'').replace(/</g,'&lt;')}</textarea>
          </div>
          <div>
            <div style="font-size:10px;font-weight:600;color:#ffaa44;text-transform:uppercase;letter-spacing:.4px;margin-bottom:4px;">Premissas DESFAVORÁVEL</div>
            <textarea id="rep_prem_desfavoravel" class="config-textarea" style="height:80px;font-size:11px;" placeholder="uma regra por linha" oninput="repSync()">${(repAnchors.prem_desfavoravel||'').replace(/</g,'&lt;')}</textarea>
          </div>
        </div>
        <div style="display:flex;gap:8px;align-items:center;margin-bottom:12px;">
          <button class="tbtn tbtn-primary" style="font-size:11px;padding:7px 16px;" onclick="repSync();repPersistir();if(typeof HubBatch!=='undefined')HubBatch.renderUI('repBatchContainer',repDB,repAnchors,'social');showToastSafe('✅ Premissas salvas — rode o classificador novamente para re-testar.')">💾 Salvar e re-rodar</button>
          <span style="font-size:10px;color:var(--text-muted);">Salva as premissas e reinicia o classificador com as novas regras.</span>
        </div>
        <div>
          <div style="font-size:10px;font-weight:600;color:var(--text-muted);text-transform:uppercase;letter-spacing:.4px;margin-bottom:5px;">Ou cole JSON de premissas da IA</div>
          <textarea id="repRefinarJson" class="config-textarea" style="height:64px;font-family:monospace;font-size:11px;" placeholder='{"prem_positivo":"…","prem_negativo":"…","prem_favoravel":"…","prem_desfavoravel":"…"}'></textarea>
          <div style="display:flex;gap:8px;margin-top:8px;align-items:center;">
            <button class="tbtn" style="font-size:11px;padding:6px 14px;color:#66dd88;border-color:rgba(102,221,136,0.3);" onclick="repAplicarPremissasRefinadas()">✅ Aplicar JSON</button>
            <div id="repRefinarStatus" style="font-size:11px;color:var(--green);"></div>
          </div>
        </div>
      </div>`;
  }

  const rail = REP_PASSOS.map((p, i) => {
    const ativo = i === repPasso, feito = i < repPasso;
    const cor = ativo ? 'var(--orange-2)' : (feito ? '#66dd88' : 'var(--text-muted)');
    const bg = ativo ? 'hsla(var(--theme-h),90%,50%,0.12)' : 'transparent';
    return `<button onclick="repIrPasso(${i})" style="display:flex;align-items:center;gap:8px;width:100%;text-align:left;background:${bg};border:none;border-left:2px solid ${ativo?'var(--orange-2)':'transparent'};padding:7px 10px;cursor:pointer;border-radius:0 6px 6px 0;">
      <span style="flex-shrink:0;width:18px;height:18px;border-radius:50%;border:1.5px solid ${cor};color:${cor};font-size:9px;font-weight:700;display:flex;align-items:center;justify-content:center;">${feito?'✓':(i+1)}</span>
      <span style="font-size:11px;color:${ativo?'var(--text-primary)':'var(--text-muted)'};font-weight:${ativo?'600':'400'};line-height:1.3;">${p.titulo}</span>
    </button>`;
  }).join('');

  document.getElementById('tabBody').innerHTML = `
    <div style="max-width:920px;margin:0 auto;padding:8px 0 40px;">
      <div style="margin-bottom:20px;">
        <div style="font-size:17px;font-weight:600;color:var(--text-primary);display:flex;align-items:center;gap:8px;">
          <svg viewBox="0 0 24 24" style="width:18px;height:18px;fill:none;stroke:var(--orange-2);stroke-width:2;stroke-linecap:round;stroke-linejoin:round"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
          Integração com o Reputaition — passo a passo
        </div>
      </div>
      <div style="display:flex;gap:20px;align-items:flex-start;">
        <div style="flex-shrink:0;width:230px;position:sticky;top:8px;">${rail}</div>
        <div class="config-panel" style="flex:1;margin:0;">
          <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:4px;">
            <div style="display:flex;align-items:center;gap:10px;">
              <span style="font-size:13px;font-weight:700;color:var(--orange-2);">Passo ${repPasso+1}/${REP_PASSOS.length}</span>
              ${repTipoBadge(passo.tipo)}
            </div>
            <button class="tbtn tbtn-primary" style="font-size:11px;padding:5px 14px;" onclick="repPersistir()">💾 Salvar</button>
          </div>
          <div style="font-size:16px;font-weight:600;color:var(--text-primary);margin-bottom:14px;">${passo.titulo}</div>
          ${corpo}
          <div style="display:flex;justify-content:space-between;margin-top:24px;padding-top:16px;border-top:1px solid rgba(255,255,255,0.08);">
            <button class="tbtn" style="font-size:12px;padding:8px 18px;${repPasso===0?'opacity:.4;pointer-events:none;':''}" onclick="repIrPasso(${repPasso-1})">← Anterior</button>
            ${repPasso < REP_PASSOS.length-1
              ? `<button class="tbtn tbtn-primary" style="font-size:12px;padding:8px 18px;" onclick="repIrPasso(${repPasso+1})">Próximo →</button>`
              : `<span style="font-size:12px;color:var(--green);align-self:center;">✅ Fluxo completo</span>`}
          </div>
        </div>
      </div>
    </div>`;
  if (passo.id === 'refinar') requestAnimationFrame(repMontarCalibracao);
  if (passo.id === 'classificar') requestAnimationFrame(() => {
    // Inicializa o classificador batch inline
    if (repDB.length && typeof HubBatch !== 'undefined') {
      HubBatch.renderUI('repBatchContainer', repDB, {
        nome: repAnchors.nome,
        premissas_rs: [
          repAnchors.regras_globais,
          repAnchors.logica_etapa1,
          repAnchors.logica_etapa2,
          repAnchors.prem_positivo ? 'POSITIVO:\n' + repAnchors.prem_positivo : '',
          repAnchors.prem_negativo ? 'NEGATIVO:\n' + repAnchors.prem_negativo : '',
          repAnchors.prem_favoravel ? 'FAVORÁVEL:\n' + repAnchors.prem_favoravel : '',
          repAnchors.prem_desfavoravel ? 'DESFAVORÁVEL:\n' + repAnchors.prem_desfavoravel : '',
          repAnchors.prem_neutro ? 'NEUTRO:\n' + repAnchors.prem_neutro : '',
        ].filter(Boolean).join('\n\n'),
        foco_cliente_rs: repAnchors.foco_cliente_rs || '',
      }, 'social', () => {
        // Após classificar tudo, monta a calibração automaticamente
        repMontarCalibracao();
      });
    }
    // Monta calibração se já há dados classificados
    repMontarCalibracao();
  });
}

// ════════════════════════════════════════════════════════════
// ENXOVAL DE CRISE — banco de premissas compartilhado (D1)
// ════════════════════════════════════════════════════════════
const ENX_CAMPOS_PREMISSA = ['regras_globais','logica_etapa1','logica_etapa2','prem_positivo','prem_negativo','prem_favoravel','prem_desfavoravel','prem_neutro'];
const ENX_CATEGORIAS = ['Crise genérica','Governo / Órgão público','Energia','Saneamento','Agronegócio','Saúde / Pharma','Financeiro','Varejo/Consumo','Outro'];

let enxState = { lista: null, carregando: false, busca: '', categoria: '', erro: '' };

// Pacote padrão sempre disponível, mesmo antes de qualquer um ser salvo no banco —
// cobre ~70% dos casos de crise reputacional segundo o que a equipe levantou.
const ENX_KIT_GENERICO = {
  id: null,
  titulo: '🆘 Kit de Crise Genérico',
  categoria: 'Crise genérica',
  tags: 'crise,generico,emergencial,ponto de partida',
  descricao: 'Pacote de emergência para começar a classificar enquanto o cadastro definitivo do cliente não está pronto. Cobre os padrões mais comuns de crítica/crise. Troque {{CLIENTE}} pelo nome do cliente e ajuste antes de rodar a base inteira.',
  conteudo: JSON.stringify({
    regras_globais: 'A publicação trata de {{CLIENTE}}, suas marcas, produtos, executivos ou porta-vozes oficiais.\nMenções que citam {{CLIENTE}} apenas de forma incidental, sem relação com o fato em apuração, não devem ser classificadas.',
    logica_etapa1: 'Classifique como NEGATIVO quando a publicação critica, culpa ou cobra {{CLIENTE}} por algum fato, decisão, produto ou comportamento.\nClassifique como POSITIVO quando a publicação elogia, agradece ou reconhece algo positivo feito por {{CLIENTE}}.\nClassifique como NEUTRO quando é apenas informativo, sem juízo de valor (nota factual, agenda, dado de mercado).',
    logica_etapa2: 'Classifique como DESFAVORÁVEL quando, além de negativa, a publicação atribui responsabilidade direta a {{CLIENTE}} por um dano, prejuízo ou falha (ambiental, social, financeiro, de produto ou de conduta).\nClassifique como FAVORÁVEL quando a publicação reforça a reputação, a credibilidade ou a competência de {{CLIENTE}} diante de terceiros.',
    prem_positivo: 'A publicação reconhece uma ação, entrega ou resultado positivo de {{CLIENTE}}.\nA publicação agradece ou elogia {{CLIENTE}} por algo concreto.\nA publicação noticia um reconhecimento externo (prêmio, ranking, certificação) recebido por {{CLIENTE}}.',
    prem_negativo: 'A publicação critica, reclama ou expressa insatisfação com {{CLIENTE}}, seus produtos ou serviços.\nA publicação relata um problema, falha, atraso ou prejuízo associado a {{CLIENTE}}.\nA publicação questiona decisões, condutas ou declarações de executivos/porta-vozes de {{CLIENTE}}.',
    prem_favoravel: 'A publicação atribui a {{CLIENTE}} um papel de solução, liderança ou responsabilidade bem cumprida diante do fato relatado.\nA publicação compara {{CLIENTE}} favoravelmente a concorrentes ou ao setor.',
    prem_desfavoravel: 'A publicação responsabiliza {{CLIENTE}} por um impacto social, ambiental, econômico ou à saúde de terceiros.\nA publicação associa {{CLIENTE}} a um escândalo, investigação, autuação ou processo judicial.\nA publicação relata omissão ou demora de {{CLIENTE}} em responder a um problema já conhecido.',
    prem_neutro: 'A publicação apenas menciona {{CLIENTE}} em um contexto informativo, sem elogio ou crítica (agenda, dado de mercado, nota factual).',
    mensagens_chave: [
      { mensagem: 'Resposta à crise', premissas: 'A publicação menciona uma resposta oficial, nota ou posicionamento de {{CLIENTE}} sobre o fato em apuração.', prem_exclusao: '' },
      { mensagem: 'Responsabilização', premissas: 'A publicação atribui culpa ou responsabilidade direta a {{CLIENTE}} pelo fato.', prem_exclusao: '' },
    ],
    temas: [
      { nome: 'Crise / Repercussão', grupo: 'Reputação', prem_identificar: 'A publicação repercute, comenta ou reage ao fato gerador da crise envolvendo {{CLIENTE}}.', prem_nao_identificar: 'A publicação é só institucional, sem relação com o fato.' },
    ],
  }),
  usos: 0, criado_por: null, builtin: true,
};

async function enxCarregar() {
  enxState.carregando = true; enxState.erro = '';
  renderEnxoval();
  try {
    const params = new URLSearchParams();
    if (enxState.busca) params.set('q', enxState.busca);
    if (enxState.categoria) params.set('categoria', enxState.categoria);
    const res = await fetch('/api/reputaition/enxoval' + (params.toString() ? '?' + params.toString() : ''));
    if (!res.ok) throw new Error('Erro ao carregar o banco (HTTP ' + res.status + ')');
    enxState.lista = await res.json();
  } catch(e) {
    console.error(e);
    enxState.erro = e.message;
    enxState.lista = [];
  } finally {
    enxState.carregando = false;
    renderEnxoval();
  }
}

function enxFiltrar(v) { enxState.busca = v; clearTimeout(window._enxTimer); window._enxTimer = setTimeout(enxCarregar, 350); }
function enxFiltrarCategoria(v) { enxState.categoria = v; enxCarregar(); }

function renderEnxoval() {
  if (enxState.lista === null && !enxState.carregando) enxCarregar();
  const cont = document.getElementById('tabBody');
  if (!cont) return;

  const cards = (enxState.lista || []).map(p => enxCardHTML(p, false)).join('');
  const buscaVazia = !enxState.busca && !enxState.categoria;

  cont.innerHTML = `
    <div style="max-width:920px;margin:0 auto;padding:8px 0 40px;">
      <div style="margin-bottom:18px;">
        <div style="font-size:17px;font-weight:600;color:var(--text-primary);display:flex;align-items:center;gap:8px;margin-bottom:6px;">
          <svg viewBox="0 0 24 24" style="width:18px;height:18px;fill:none;stroke:var(--orange-2);stroke-width:2;stroke-linecap:round;stroke-linejoin:round"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
          Enxoval de Crise — banco de premissas compartilhado
        </div>
        <div style="font-size:12px;color:var(--text-secondary);line-height:1.6;max-width:680px;">
          Pacotes de premissas reutilizáveis entre clientes. Visível e editável por toda a equipe. Use como ponto de partida (~70% de cobertura) e sempre calibre com a amostra real do cliente depois.
        </div>
      </div>

      <div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:16px;align-items:center;">
        <input type="text" class="macro-input" style="flex:1;min-width:180px;" placeholder="🔎 Buscar por título, tag ou categoria…" value="${(enxState.busca||'').replace(/"/g,'&quot;')}" oninput="enxFiltrar(this.value)">
        <select class="macro-input" style="width:auto;" onchange="enxFiltrarCategoria(this.value)">
          <option value="">Todas categorias</option>
          ${ENX_CATEGORIAS.map(c => `<option value="${c}" ${enxState.categoria===c?'selected':''}>${c}</option>`).join('')}
        </select>
        <button class="tbtn tbtn-primary" style="font-size:11px;padding:7px 16px;" onclick="enxAbrirForm(null)">+ Novo pacote</button>
        <button class="tbtn" style="font-size:11px;padding:7px 16px;" onclick="enxAbrirFormDoClienteAtual()">💾 Salvar premissas do cliente atual</button>
      </div>

      ${buscaVazia ? enxCardHTML(ENX_KIT_GENERICO, true) : ''}

      ${enxState.erro ? `<div style="padding:12px 16px;background:rgba(255,96,96,0.08);border:1px solid rgba(255,96,96,0.25);border-radius:var(--r-md);font-size:12px;color:var(--red);margin-bottom:14px;">❌ ${enxState.erro} — confira se a API <code>/api/reputaition/enxoval</code> e a tabela D1 já existem.</div>` : ''}

      ${enxState.carregando ? `<div style="text-align:center;padding:30px;color:var(--text-muted);font-size:12px;"><span class="spinner"></span> Carregando banco…</div>` : (cards || `<div style="text-align:center;padding:40px 20px;color:var(--text-muted);font-size:12px;">Nenhum pacote salvo ainda neste filtro. Salve as premissas de um cliente calibrado para começar o banco.</div>`)}
    </div>`;
}

function enxCardHTML(p, isBuiltin) {
  const conteudo = (() => { try { return JSON.parse(p.conteudo || '{}'); } catch(e) { return {}; } })();
  const tags = (p.tags||'').split(',').map(t=>t.trim()).filter(Boolean);
  return `
    <div class="enx-card">
      <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:10px;margin-bottom:8px;">
        <div style="font-size:14px;font-weight:700;color:var(--text-primary);">${(p.titulo||'').replace(/</g,'&lt;')}</div>
        <div style="display:flex;gap:6px;flex-wrap:wrap;flex-shrink:0;">
          ${p.categoria ? `<span class="enx-tag cat">${p.categoria}</span>` : ''}
          ${isBuiltin ? `<span class="enx-tag">modelo embutido</span>` : `<span class="enx-tag">usado ${p.usos||0}×</span>`}
        </div>
      </div>
      ${p.descricao ? `<div style="font-size:11px;color:var(--text-secondary);line-height:1.6;margin-bottom:8px;">${p.descricao.replace(/</g,'&lt;')}</div>` : ''}
      ${tags.length ? `<div style="display:flex;gap:5px;flex-wrap:wrap;margin-bottom:10px;">${tags.map(t=>`<span class="enx-tag">${t}</span>`).join('')}</div>` : ''}
      <div style="display:flex;gap:8px;flex-wrap:wrap;">
        <button class="tbtn" style="font-size:11px;padding:6px 12px;" onclick='enxVerCompleto(${JSON.stringify(p).replace(/'/g,"&#39;")})'>👁 Ver completo</button>
        <button class="tbtn tbtn-primary" style="font-size:11px;padding:6px 12px;" onclick='enxUsar(${JSON.stringify(p).replace(/'/g,"&#39;")})'>✅ Usar no cliente atual</button>
        ${isBuiltin ? `<button class="tbtn" style="font-size:11px;padding:6px 12px;color:#66dd88;border-color:rgba(102,221,136,0.3);" onclick="enxImportarKitGenerico()">📥 Importar para o banco compartilhado</button>` : `<button class="tbtn" style="font-size:11px;padding:6px 12px;" onclick='enxAbrirForm(${JSON.stringify(p).replace(/'/g,"&#39;")})'>✏️ Editar</button><button class="tbtn tbtn-danger" style="font-size:11px;padding:6px 12px;" onclick="enxRemover(${p.id})">🗑 Remover</button>`}
      </div>
    </div>`;
}

function enxVerCompleto(p) {
  const conteudo = (() => { try { return JSON.parse(p.conteudo || '{}'); } catch(e) { return {}; } })();
  const linhas = ENX_CAMPOS_PREMISSA.map(k => conteudo[k] ? `
    <div style="margin-bottom:12px;">
      <div style="font-size:10px;font-weight:700;color:var(--orange-2);text-transform:uppercase;letter-spacing:.4px;margin-bottom:4px;">${k.replace(/_/g,' ')}</div>
      <div style="font-size:12px;color:var(--text-secondary);line-height:1.6;white-space:pre-wrap;background:rgba(0,0,0,0.18);border-radius:6px;padding:8px 10px;">${conteudo[k].replace(/</g,'&lt;')}</div>
    </div>` : '').join('');
  const msgs = (conteudo.mensagens_chave||[]).map(m => `<li style="margin-bottom:4px;"><strong>${(m.mensagem||'').replace(/</g,'&lt;')}</strong> — ${(m.premissas||'').replace(/</g,'&lt;')}</li>`).join('');
  const temas = (conteudo.temas||[]).map(t => `<li style="margin-bottom:4px;"><strong>${(t.nome||'').replace(/</g,'&lt;')}</strong> [${t.grupo||'—'}] — ${(t.prem_identificar||'').replace(/</g,'&lt;')}</li>`).join('');
  abrirModalGenerico(`📦 ${p.titulo}`, `
    ${p.descricao ? `<p style="font-size:12px;color:var(--text-secondary);line-height:1.6;margin-bottom:14px;">${p.descricao.replace(/</g,'&lt;')}</p>` : ''}
    ${linhas}
    ${msgs ? `<div style="margin-top:14px;"><div style="font-size:10px;font-weight:700;color:var(--orange-2);text-transform:uppercase;letter-spacing:.4px;margin-bottom:6px;">Mensagens-chave</div><ul style="margin:0;padding-left:18px;font-size:12px;color:var(--text-secondary);">${msgs}</ul></div>` : ''}
    ${temas ? `<div style="margin-top:14px;"><div style="font-size:10px;font-weight:700;color:var(--orange-2);text-transform:uppercase;letter-spacing:.4px;margin-bottom:6px;">Temas sugeridos</div><ul style="margin:0;padding-left:18px;font-size:12px;color:var(--text-secondary);">${temas}</ul></div>` : ''}
  `, [{ label:'Fechar', cls:'', onclick:'fecharModalGenerico()' }]);
}

// Substitui {{CLIENTE}} pelo nome atual e aplica o pacote ao repAnchors,
// sempre por adição (não sobrescreve premissas já escritas pelo analista).
function enxUsar(p) {
  const nome = (repAnchors.nome || '').trim();
  if (!nome) { showToastSafe('⚠️ Defina o nome do cliente no passo "Empresa — Dados" antes de aplicar um pacote.'); return; }
  if (!confirm(`Aplicar o pacote "${p.titulo}" ao cliente "${nome}"?\n\nAs premissas serão acrescentadas (não substituem o que já existe) com {{CLIENTE}} trocado por "${nome}". Revise e calibre depois.`)) return;
  const conteudo = (() => { try { return JSON.parse(p.conteudo || '{}'); } catch(e) { return {}; } })();
  const subst = (s) => String(s||'').replace(/\{\{\s*CLIENTE\s*\}\}/gi, nome);
  let n = 0;
  ENX_CAMPOS_PREMISSA.forEach(k => {
    const novo = subst(conteudo[k] || '').trim();
    if (!novo) return;
    const atual = (repAnchors[k] || '').trim();
    if (!atual) { repAnchors[k] = novo; n++; }
    else if (!atual.includes(novo.split('\n')[0])) { repAnchors[k] = atual + '\n' + novo; n++; }
  });
  (conteudo.mensagens_chave || []).forEach(m => {
    const nomeMsg = subst(m.mensagem||'');
    if (nomeMsg && !repAnchors.mensagens_chave.some(x => x.mensagem === nomeMsg)) {
      repAnchors.mensagens_chave.push({ mensagem: nomeMsg, premissas: subst(m.premissas||''), prem_exclusao: subst(m.prem_exclusao||'') });
      n++;
    }
  });
  (conteudo.temas || []).forEach(t => {
    const nomeTema = subst(t.nome||'');
    if (nomeTema && !repAnchors.temas.some(x => x.nome === nomeTema)) {
      repAnchors.temas.push({ nome: nomeTema, grupo: t.grupo||'', prem_identificar: subst(t.prem_identificar||''), prem_nao_identificar: subst(t.prem_nao_identificar||'') });
      n++;
    }
  });
  localStorage.setItem('rep_anchors', JSON.stringify(repAnchors));
  if (p.id) enxIncrementarUso(p.id);
  showToastSafe(`✅ Pacote aplicado (${n} campo(s)/itens). Revise no passo "Configuração de Prompt".`);
  setMainTab('cadastro', document.getElementById('mtCadastro'));
  repIrPasso(REP_PASSOS.findIndex(x => x.id === 'prompt'));
}

async function enxIncrementarUso(id) {
  try { await fetch('/api/reputaition/enxoval', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ id, acao:'usar' }) }); } catch(e) {}
}

async function enxImportarKitGenerico() {
  try {
    const res = await fetch('/api/reputaition/enxoval', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({
      titulo: ENX_KIT_GENERICO.titulo, categoria: ENX_KIT_GENERICO.categoria, tags: ENX_KIT_GENERICO.tags,
      descricao: ENX_KIT_GENERICO.descricao, conteudo: ENX_KIT_GENERICO.conteudo,
    }) });
    if (!res.ok) throw new Error('HTTP ' + res.status);
    showToastSafe('✅ Kit de Crise Genérico importado para o banco compartilhado!');
    enxCarregar();
  } catch(e) { showToastSafe('❌ Não consegui importar: ' + e.message); }
}

function enxRemover(id) {
  if (!confirm('Remover este pacote do banco compartilhado? Esta ação não pode ser desfeita.')) return;
  fetch('/api/reputaition/enxoval?id=' + id, { method:'DELETE' })
    .then(r => { if (!r.ok) throw new Error('HTTP ' + r.status); showToastSafe('🗑 Pacote removido.'); enxCarregar(); })
    .catch(e => showToastSafe('❌ ' + e.message));
}

function enxAbrirFormDoClienteAtual() {
  const nome = (repAnchors.nome || '').trim();
  if (!nome) { showToastSafe('⚠️ Defina o nome do cliente no passo "Empresa — Dados" primeiro.'); return; }
  const subst = (s) => String(s||'').split(new RegExp('\\b' + nome.replace(/[.*+?^${}()|[\]\\]/g,'\\$&') + '\\b','gi')).join('{{CLIENTE}}');
  const conteudo = {};
  ENX_CAMPOS_PREMISSA.forEach(k => { conteudo[k] = subst(repAnchors[k]||''); });
  conteudo.mensagens_chave = (repAnchors.mensagens_chave||[]).map(m => ({ mensagem: subst(m.mensagem), premissas: subst(m.premissas), prem_exclusao: subst(m.prem_exclusao) }));
  conteudo.temas = (repAnchors.temas||[]).map(t => ({ nome: subst(t.nome), grupo: t.grupo, prem_identificar: subst(t.prem_identificar), prem_nao_identificar: subst(t.prem_nao_identificar) }));
  enxAbrirForm({
    titulo: `Premissas — ${nome} (generalizado)`, categoria: '', tags: '',
    descricao: `Gerado a partir do cadastro de ${nome}. Nome substituído por {{CLIENTE}} — revise antes de salvar.`,
    conteudo: JSON.stringify(conteudo),
  });
}

function enxAbrirForm(pacote) {
  const p = pacote || { titulo:'', categoria:'', tags:'', descricao:'', conteudo:'{}' };
  const conteudo = (() => { try { return JSON.parse(p.conteudo || '{}'); } catch(e) { return {}; } })();
  const ta = (k, lbl) => `
    <div style="margin-bottom:12px;">
      <label class="field-label" style="margin-bottom:4px;">${lbl}</label>
      <textarea id="enxF_${k}" class="config-textarea" style="height:70px;">${(conteudo[k]||'').replace(/</g,'&lt;')}</textarea>
    </div>`;
  abrirModalGenerico(p.id ? '✏️ Editar pacote' : '➕ Novo pacote de premissas', `
    <div style="margin-bottom:12px;">
      <label class="field-label">Título *</label>
      <input id="enxF_titulo" type="text" class="macro-input" style="width:100%;" value="${(p.titulo||'').replace(/"/g,'&quot;')}" placeholder="Ex: Crise — Saneamento / Vazamento">
    </div>
    <div style="display:flex;gap:10px;margin-bottom:12px;">
      <div style="flex:1;">
        <label class="field-label">Categoria</label>
        <select id="enxF_categoria" class="macro-input" style="width:100%;">
          <option value="">—</option>
          ${ENX_CATEGORIAS.map(c => `<option value="${c}" ${p.categoria===c?'selected':''}>${c}</option>`).join('')}
        </select>
      </div>
      <div style="flex:2;">
        <label class="field-label">Tags (separadas por vírgula)</label>
        <input id="enxF_tags" type="text" class="macro-input" style="width:100%;" value="${(p.tags||'').replace(/"/g,'&quot;')}" placeholder="crise, governo, vazamento">
      </div>
    </div>
    <div style="margin-bottom:14px;">
      <label class="field-label">Descrição — quando usar este pacote</label>
      <textarea id="enxF_descricao" class="config-textarea" style="height:54px;">${(p.descricao||'').replace(/</g,'&lt;')}</textarea>
    </div>
    <div class="field-hint" style="margin-bottom:10px;">Use <code style="background:rgba(0,0,0,0.25);padding:1px 5px;border-radius:3px;">{{CLIENTE}}</code> no lugar do nome do cliente — será substituído automaticamente ao aplicar.</div>
    ${ta('regras_globais','Regras Globais')}
    ${ta('logica_etapa1','Lógica Etapa 1 (pos/neg/neutro)')}
    ${ta('logica_etapa2','Lógica Etapa 2 (fav/desf)')}
    ${ta('prem_positivo','Premissas POSITIVO')}
    ${ta('prem_negativo','Premissas NEGATIVO')}
    ${ta('prem_favoravel','Premissas FAVORÁVEL')}
    ${ta('prem_desfavoravel','Premissas DESFAVORÁVEL')}
    ${ta('prem_neutro','Premissas NEUTRO')}
    <div class="field-hint">Mensagens-chave e temas sugeridos podem ser ajustados depois de salvo, editando o pacote.</div>
  `, [
    { label:'Cancelar', cls:'', onclick:'fecharModalGenerico()' },
    { label: p.id ? 'Salvar alterações' : 'Salvar no banco', cls:'tbtn-primary', onclick:`enxSalvarForm(${p.id||'null'}, ${JSON.stringify(conteudo).replace(/'/g,"&#39;")})` },
  ]);
}

async function enxSalvarForm(id, conteudoBase) {
  const titulo = (document.getElementById('enxF_titulo')?.value||'').trim();
  if (!titulo) { showToastSafe('⚠️ Dê um título ao pacote.'); return; }
  const conteudo = Object.assign({}, conteudoBase);
  ENX_CAMPOS_PREMISSA.forEach(k => { const el = document.getElementById('enxF_'+k); if (el) conteudo[k] = el.value; });
  const payload = {
    titulo, categoria: document.getElementById('enxF_categoria')?.value || '',
    tags: document.getElementById('enxF_tags')?.value || '',
    descricao: document.getElementById('enxF_descricao')?.value || '',
    conteudo: JSON.stringify(conteudo),
  };
  if (id) payload.id = id;
  try {
    const res = await fetch('/api/reputaition/enxoval', { method: id ? 'PUT' : 'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify(payload) });
    if (!res.ok) throw new Error('HTTP ' + res.status);
    fecharModalGenerico();
    showToastSafe(id ? '✅ Pacote atualizado!' : '✅ Pacote salvo no banco compartilhado!');
    enxCarregar();
  } catch(e) { showToastSafe('❌ Erro ao salvar: ' + e.message); }
}

// ── Modal genérico reutilizável ──
function abrirModalGenerico(titulo, corpoHTML, botoes) {
  const el = document.getElementById('genModal');
  el.innerHTML = `
    <div class="ov-backdrop" onclick="if(event.target===this) fecharModalGenerico()">
      <div class="ov-box">
        <div class="ov-head"><div class="ov-title">${titulo}</div><button class="ov-close" onclick="fecharModalGenerico()">✕</button></div>
        <div class="ov-body">${corpoHTML}</div>
        <div class="ov-foot">${(botoes||[]).map(b => `<button class="tbtn ${b.cls||''}" style="font-size:12px;padding:8px 18px;" onclick="${b.onclick}">${b.label}</button>`).join('')}</div>
      </div>
    </div>`;
  el.style.display = 'block';
}
function fecharModalGenerico() { const el = document.getElementById('genModal'); el.style.display = 'none'; el.innerHTML = ''; }

// ════════════════════════════════════════════════════════════
// BOOTSTRAP
// ════════════════════════════════════════════════════════════
document.getElementById('navbar-container').innerHTML = renderNavbar('reputaition');
renderReputaition();
  </script>
</body>
</html>
